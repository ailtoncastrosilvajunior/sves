# Copiar para `.env` e preencher. O ficheiro `.env` não deve ser commitado.

# Postgres (Rails development sem DATABASE_URL usa estes valores)
DATABASE_NAME=sves_development
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=a_sua_senha_aqui
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432

# Opcional: URL completa PostgreSQL (`gem "pg"` — não uses esquema mysql2 na mesma URL)
# DATABASE_URL=postgresql://USUARIO:SENHA@HOST:25060/NOME_BD?sslmode=require&gssencmode=disable
#
# DigitalOcean (recomendado): descarregar CA no painel → config/certs/do-ca.crt e:
# DATABASE_URL=postgresql://USUARIO:SENHA@HOST:25060/NOME_BD?sslmode=verify-full&sslrootcert=/rails/config/certs/do-ca.crt

# SSL (servidor gerido / Droplet): ex. require ou verify-full
# DATABASE_SSLMODE=require

# Testes por omissão usam outro nome de base no mesmo servidor (evita usar a mesma colecção que desenvolvimento)
# DATABASE_TEST_NAME=sves_test

# Produção só com várias BD Solid (opcional; por defeito reutiliza DATABASE_NAME para cache/fila/cable):
# DATABASE_CACHE_NAME=sves_cache
# DATABASE_QUEUE_NAME=sves_queue
# DATABASE_CABLE_NAME=sves_cable

# Conta inicial opcional (rails db:seed) — defina palavra‑passe forte em produção.
# SVES_ADMIN_EMAIL=coordenacao@exemplo.invalid
# SVES_ADMIN_PASSWORD=
#
# Servos sem user mas com e-mail recebem conta no seed se ainda não existir User para esse e-mail.
# Omitir esta variável → usa por defeito sves2026.1 apenas para desenvolvimento.
# SVES_SEED_SERVO_PASSWORD=

# Campos apenas informativos / outras apps (Rails ignora por omissão)
# DS_API_DB_ENV=dev
# DB_ENV=dev
