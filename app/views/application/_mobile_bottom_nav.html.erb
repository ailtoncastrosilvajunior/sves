<% if user_signed_in? %>
  <% tab = mobile_nav_tab %>
  <% icon_cls = lambda { |on| "#{mobile_nav_icon_classes(on)} size-[1.375rem] shrink-0" } %>
  <nav
    class="lg:hidden fixed bottom-0 left-0 right-0 z-[60] border-t border-stone-200/90 bg-stone-50/95 px-1.5 pt-1 pb-[max(0.35rem,env(safe-area-inset-bottom))] shadow-[0_-8px_32px_-12px_rgba(28,25,23,0.14)] backdrop-blur-xl supports-[backdrop-filter]:bg-stone-50/80"
    aria-label="Navegação principal">
    <div class="mx-auto grid w-full max-w-2xl <%= mobile_nav_grid_class %> gap-px px-0">
      <%= link_to root_path,
                  { class: mobile_nav_link_classes(tab == :home) }.merge(mobile_nav_aria_current(tab == :home)) do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor" aria-hidden="true" class="<%= icon_cls.call(tab == :home) %>">
          <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.153-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
        </svg>
        <span class="truncate">Início</span>
      <% end %>

      <% if pode_gerir_painel? %>
      <%= link_to mobile_edicao_tab_url,
                  { class: mobile_nav_link_classes(tab == :edicao) }.merge(mobile_nav_aria_current(tab == :edicao)) do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor" aria-hidden="true" class="<%= icon_cls.call(tab == :edicao) %>">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5a2.25 2.25 0 0 0 2.25-2.25m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5a2.25 2.25 0 0 1 2.25 2.25v7.5" />
        </svg>
        <span class="truncate">Edição</span>
      <% end %>

      <%= link_to equipes_em_curso_path,
                  { class: mobile_nav_link_classes(tab == :equipes) }.merge(mobile_nav_aria_current(tab == :equipes)) do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor" aria-hidden="true" class="<%= icon_cls.call(tab == :equipes) %>">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z" />
        </svg>
        <span class="truncate">Equipes</span>
      <% end %>
      <% else %>
      <% cen_href = mobile_nav_cenaculo_href || root_path %>
      <%= link_to cen_href,
                  { class: mobile_nav_link_classes(tab == :cenaculo) }.merge(mobile_nav_aria_current(tab == :cenaculo)) do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor" aria-hidden="true" class="<%= icon_cls.call(tab == :cenaculo) %>">
          <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.09 9.09 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 1 0-4.682 2.72 9.09 9.09 0 0 0 3.741.479m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
        </svg>
        <span class="truncate">Cenáculo</span>
      <% end %>
      <% end %>

      <% if pode_gerir_painel? %>
      <%= link_to servos_path,
                  { class: mobile_nav_link_classes(tab == :servos) }.merge(mobile_nav_aria_current(tab == :servos)) do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor" aria-hidden="true" class="<%= icon_cls.call(tab == :servos) %>">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
        </svg>
        <span class="truncate">Servos</span>
      <% end %>
      <% end %>

      <%= link_to materiais_apoio_path,
                  { class: mobile_nav_link_classes(tab == :apoio) }.merge(mobile_nav_aria_current(tab == :apoio)) do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor" aria-hidden="true" class="<%= icon_cls.call(tab == :apoio) %>">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5.586a1 1 0 0 1 .707.293l5.414 5.414a1 1 0 0 1 .293.707V19a2 2 0 0 1-2 2Z" />
        </svg>
        <span class="truncate">Apoio</span>
      <% end %>

      <% if pode_gerir_painel? %>
      <%= link_to edicoes_path,
                  { class: mobile_nav_link_classes(tab == :edicoes) }.merge(mobile_nav_aria_current(tab == :edicoes)) do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor" aria-hidden="true" class="<%= icon_cls.call(tab == :edicoes) %>">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75Zm0 5.25h.007v.008H3.75v-.008Zm0 5.25h.007v.008H3.75v-.008Z" />
        </svg>
        <span class="truncate">Lista</span>
      <% end %>
      <% end %>
    </div>
  </nav>
<% else %>
  <% tab_guest = mobile_nav_tab %>
  <nav
    class="lg:hidden fixed bottom-0 left-0 right-0 z-[60] border-t border-stone-200/90 bg-stone-50/95 px-4 pt-2 pb-[max(0.5rem,env(safe-area-inset-bottom))] shadow-[0_-8px_32px_-12px_rgba(28,25,23,0.14)] backdrop-blur-xl supports-[backdrop-filter]:bg-stone-50/80"
    aria-label="Navegação móvel">
    <div class="mx-auto flex max-w-md items-stretch justify-center gap-4">
      <%= link_to root_path,
                  { class: mobile_nav_link_classes(tab_guest == :home) }.merge(mobile_nav_aria_current(tab_guest == :home)) do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor" aria-hidden="true" class="<%= mobile_nav_icon_classes(tab_guest == :home) %> size-[1.5rem] shrink-0">
          <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.153-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
        </svg>
        <span class="truncate pt-px">Site</span>
      <% end %>
      <%= link_to new_session_path,
                  { class: mobile_nav_link_classes(tab_guest == :sessao) }.merge(mobile_nav_aria_current(tab_guest == :sessao)) do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor" aria-hidden="true" class="<%= mobile_nav_icon_classes(tab_guest == :sessao) %> size-[1.5rem] shrink-0">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15M12 9l-3 3m0 0 3 3m-3-3h12.75" />
        </svg>
        <span class="truncate pt-px">Painel</span>
      <% end %>
    </div>
  </nav>
<% end %>
