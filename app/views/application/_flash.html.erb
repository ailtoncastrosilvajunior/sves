<% flash.each do |tipo, mensagem| %>
  <% next if mensagem.blank? %>
  <div class="mx-auto max-w-6xl px-4 pb-0 pt-4 text-sm sm:px-6 lg:px-8">
    <div role="status" class="break-words rounded-xl border border-stone-200 bg-white px-4 py-3 text-stone-800 shadow-sm <%= tipo.to_s == "alert" ? "border-amber-300/80 bg-amber-50/90" : "border-emerald-200/80 bg-emerald-50/90" %>">
      <%= mensagem %>
    </div>
  </div>
<% end %>
