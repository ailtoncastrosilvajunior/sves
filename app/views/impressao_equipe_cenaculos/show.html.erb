<% content_for :title, t("impressao_equipe_cenaculos.page_title", edicao: @edicao.rotulo) %>

<div class="no-print toolbar-impressao">
  <div class="flex min-w-0 flex-1 flex-col gap-2 sm:flex-row sm:flex-wrap sm:items-center sm:gap-3">
    <%= link_to t("impressao_equipe_cenaculos.toolbar_voltar"), edicao_path(@edicao), data: { turbo: false } %>
    <% modo_rotulo = t("impressao_equipe_cenaculos.toolbar_modo_rotulo.#{@casais_nomes_modo}") %>
    <span class="text-xs leading-snug text-stone-600">
      <%= t("impressao_equipe_cenaculos.toolbar_modo_intro", rotulo: modo_rotulo) %>
      <%= link_to t("impressao_equipe_cenaculos.toolbar_trocar"), edicao_cenaculos_path(@edicao, anchor: "impressao-pdf-equipe"), class: "font-semibold text-teal-800 underline-offset-2 hover:text-teal-950 hover:underline", data: { turbo: false } %>
    </span>
  </div>
  <button type="button" onclick="window.print()"><%= t("impressao_equipe_cenaculos.toolbar_imprimir") %></button>
</div>

<p class="no-print muted sm:hidden" style="max-width:297mm;margin:0 auto 1rem;padding:0 4px;font-size:11px;">
  <%= t("impressao_equipe_cenaculos.dica_leitura_mobile_html") %>
</p>
<p class="no-print muted hidden sm:block" style="max-width:297mm;margin:0 auto 1rem;padding:0 4px;font-size:11px;">
  <%= t("impressao_equipe_cenaculos.dica_pdf_backgrounds_html") %>
</p>

<div class="sheet">
  <header class="doc-head">
    <h1><%= t("impressao_equipe_cenaculos.titulo_documento") %></h1>
    <p class="sub"><%= t("impressao_equipe_cenaculos.subtitulo") %></p>
    <p class="edicao"><%= @edicao.rotulo %></p>
    <p class="participantes-modo-doc"><%= t("impressao_equipe_cenaculos.participantes_modo.#{@casais_nomes_modo}") %></p>
  </header>

  <div class="coord-box">
    <strong><%= t("impressao_equipe_cenaculos.coord_titulo") %></strong>
    <% if @coordenacao_geral_linhas.any? %>
      <p class="coord-nomes-inline"><%= @coordenacao_geral_linhas.join(" · ") %></p>
    <% else %>
      <p class="muted" style="margin:0;"><%= t("impressao_equipe_cenaculos.coord_vazio") %></p>
    <% end %>
    <p class="muted coord-nota"><%= t("impressao_equipe_cenaculos.coord_nota_fonte") %></p>
  </div>

  <table class="grid" aria-label="<%= t("impressao_equipe_cenaculos.tabela_aria") %>">
    <colgroup>
      <col class="grid-col-num">
      <col class="grid-col-cen">
      <col class="grid-col-cor">
      <col class="grid-col-ph">
      <col class="grid-col-pm">
      <col class="grid-col-lh">
      <col class="grid-col-lm">
      <col class="grid-col-part">
    </colgroup>
    <thead>
      <tr>
        <th scope="col"><%= t("impressao_equipe_cenaculos.col_ordem") %></th>
        <th scope="col"><%= t("impressao_equipe_cenaculos.col_cenaculo") %></th>
        <th scope="col" class="cor-head"><%= t("impressao_equipe_cenaculos.col_cor") %></th>
        <th scope="col"><%= t("impressao_equipe_cenaculos.col_pastores_homens") %></th>
        <th scope="col"><%= t("impressao_equipe_cenaculos.col_pastores_mulheres") %></th>
        <th scope="col"><%= t("impressao_equipe_cenaculos.col_local_homens") %></th>
        <th scope="col"><%= t("impressao_equipe_cenaculos.col_local_mulheres") %></th>
        <th scope="col"><%= t("impressao_equipe_cenaculos.col_participantes") %></th>
      </tr>
    </thead>
    <tbody>
      <% if @cenaculos.any? %>
        <% @cenaculos.each_with_index do |cenaculo, idx| %>
          <% pm = pastores_por_sexo_texto_impressao(cenaculo) %>
          <% hex_cor = cenaculo_cor_hex_para_impressao(cenaculo) %>
          <% nome_cor = cenaculo_cor_rotulo_impressao(cenaculo) %>
          <% participantes = linhas_casais_participantes_impressao(cenaculo, casais_nomes: @casais_nomes_modo) %>
          <% participantes_lista_class = ["compact", ("participantes-modo-apelido" if @casais_nomes_modo == "apelido")].compact.join(" ") %>
          <tr>
            <td class="num"><%= idx + 1 %>º</td>
            <td class="nome-cen"><%= cenaculo.nome %></td>
            <td class="cor-cell">
              <% if hex_cor.present? %>
                <span class="swatch">
                  <span class="swatch-dot" style="<%= "background-color: #{hex_cor};" %>"></span>
                  <% if nome_cor.present? %>
                    <span class="swatch-nome"><%= nome_cor %></span>
                  <% end %>
                </span>
              <% else %>
                <span class="muted"><%= t("impressao_equipe_cenaculos.em") %></span>
              <% end %>
            </td>
            <td>
              <% if pm[:homens].present? %>
                <%= pm[:homens] %>
              <% else %>
                <span class="muted"><%= t("impressao_equipe_cenaculos.em") %></span>
              <% end %>
              <% if pm[:sem_sexo].present? %>
                <div class="pastor-sem-sexo"><%= t("impressao_equipe_cenaculos.pastores_sem_sexo", nomes: pm[:sem_sexo]) %></div>
              <% end %>
            </td>
            <td>
              <% if pm[:mulheres].present? %>
                <%= pm[:mulheres] %>
              <% else %>
                <span class="muted"><%= t("impressao_equipe_cenaculos.em") %></span>
              <% end %>
            </td>
            <td>
              <% if cenaculo.local_homens.present? %>
                <%= cenaculo.local_homens %>
              <% else %>
                <span class="muted"><%= t("impressao_equipe_cenaculos.em") %></span>
              <% end %>
            </td>
            <td>
              <% if cenaculo.local_mulheres.present? %>
                <%= cenaculo.local_mulheres %>
              <% else %>
                <span class="muted"><%= t("impressao_equipe_cenaculos.em") %></span>
              <% end %>
            </td>
            <td>
              <% if participantes.any? %>
                <ul class="<%= participantes_lista_class %>">
                  <% participantes.each do |linha| %>
                    <li><%= linha %></li>
                  <% end %>
                </ul>
              <% else %>
                <span class="muted"><%= t("impressao_equipe_cenaculos.sem_participantes") %></span>
              <% end %>
            </td>
          </tr>
        <% end %>
      <% else %>
        <tr>
          <td colspan="8" class="muted" style="text-align:center;padding:12px;"><%= t("impressao_equipe_cenaculos.sem_cenaculos_edicao") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <p class="rodape-doc"><%= t("impressao_equipe_cenaculos.rodape_nota") %></p>
</div>
