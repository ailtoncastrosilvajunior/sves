<% content_for :title, t("alterar_senha.page_title") %>

<div class="mx-auto flex min-h-[min(100dvh,48rem)] max-w-md flex-col justify-center px-4 py-10 sm:px-6 sm:py-16">
  <div class="rounded-2xl border border-stone-200/80 bg-white/90 p-6 shadow-lg shadow-stone-900/5 ring-1 ring-stone-900/[0.02] sm:p-8">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-stone-500"><%= t("alterar_senha.subtitulo") %></p>
    <h1 class="mt-4 font-display text-2xl tracking-tight text-stone-900 sm:text-3xl"><%= t("alterar_senha.titulo") %></h1>
    <p class="mt-2 text-sm leading-relaxed text-stone-600"><%= t("alterar_senha.explicacao") %></p>

    <%= form_with model: current_user, url: alterar_senha_path, method: :patch, class: "mt-8 space-y-5" do |f| %>
      <% if current_user.errors.any? %>
        <div class="rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-950">
          <ul class="list-inside list-disc">
            <% current_user.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= render "application/campo_senha_com_olho",
                 f: f,
                 campo: :current_password,
                 label: t("alterar_senha.actual_label"),
                 required: true,
                 autocomplete: "current-password" %>

      <%= render "application/campo_senha_com_olho",
                 f: f,
                 campo: :password,
                 label: t("alterar_senha.nova_label"),
                 required: true,
                 autocomplete: "new-password" %>

      <%= render "application/campo_senha_com_olho",
                 f: f,
                 campo: :password_confirmation,
                 label: t("alterar_senha.confirmar_label"),
                 required: true,
                 autocomplete: "new-password" %>

      <div class="pt-2">
        <%= f.submit t("alterar_senha.submit"),
                     class: "min-h-[48px] w-full cursor-pointer rounded-full bg-stone-900 px-5 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-stone-800 sm:min-h-[44px]" %>
      </div>
    <% end %>
  </div>
</div>
