<%# Banner promocional SVES (imagem em app/assets/images/banner-sves-casais.png) %>
<div class="mx-auto max-w-6xl px-4 pt-8 sm:px-6 sm:pt-12 lg:px-8">
  <figure class="overflow-hidden rounded-2xl bg-[#faf6f0] ring-1 ring-stone-200/70 shadow-lg shadow-stone-900/[0.06]">
    <%= image_tag "banner-sves-casais.png",
                  alt: t("inicio.banner_alt"),
                  class: "mx-auto block h-auto max-h-[min(12rem,42vw)] w-full object-contain object-center sm:max-h-[min(16rem,38vw)] lg:max-h-[min(20rem,32vw)]",
                  decoding: "async",
                  fetchpriority: "high" %>
  </figure>
</div>

<section class="relative overflow-x-clip pb-24 pt-10 sm:pt-16 lg:pb-32">
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute -left-[20%] top-0 h-[28rem] w-[28rem] rounded-full bg-slate-200/40 blur-3xl sm:h-[34rem] sm:w-[34rem]"></div>
    <div class="absolute -right-[10%] top-40 h-[24rem] w-[24rem] rounded-full bg-stone-300/35 blur-3xl"></div>
    <div class="absolute bottom-0 left-1/2 h-px w-[min(100%,48rem)] -translate-x-1/2 bg-gradient-to-r from-transparent via-stone-300/70 to-transparent"></div>
  </div>

  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <p class="text-xs font-semibold uppercase tracking-[0.22em] text-stone-500"><%= t("inicio.marca_face") %></p>
    <div class="mt-5 flex flex-col gap-5 sm:flex-row sm:flex-wrap sm:items-start sm:justify-between lg:items-center lg:gap-10">
      <h1 class="min-w-0 max-w-3xl flex-1 font-display text-3xl font-normal leading-[1.15] tracking-tight min-[375px]:text-4xl sm:text-5xl sm:leading-[1.12] lg:text-[3.35rem]">
        <span class="block text-stone-900"><%= t("inicio.titulo_linha1") %></span>
        <span class="mt-2.5 block bg-gradient-to-r from-teal-800 via-teal-700 to-emerald-900 bg-clip-text text-4xl font-semibold leading-[1.08] tracking-tight text-transparent min-[375px]:text-5xl sm:mt-3 sm:text-6xl lg:mt-3.5 lg:text-[4.35rem] lg:leading-[1.05]">
          <%= @edicao_painel&.rotulo_curto || t("inicio.titulo_edicao_fallback") %>
        </span>
      </h1>
      <% if user_signed_in? && @edicao_painel %>
        <div class="relative inline-flex max-w-full shrink-0 overflow-hidden rounded-2xl bg-gradient-to-br from-teal-900 to-emerald-900 px-5 py-4 shadow-lg shadow-teal-900/25 ring-1 ring-white/15 sm:px-6 sm:py-5"
             role="status"
             aria-label="<%= t('inicio.painel_casais.aria', count: @casais_inscritos_count, rotulo: @edicao_painel.rotulo) %>">
          <span class="sr-only"><%= t("inicio.painel_casais.rotulo_edicao", rotulo: @edicao_painel.rotulo) %>:</span>
          <div class="flex items-baseline gap-3 sm:gap-4">
            <span class="font-display text-4xl font-normal tabular-nums leading-none tracking-tight text-white sm:text-5xl">
              <%= @casais_inscritos_count %>
            </span>
            <span class="text-sm font-semibold uppercase tracking-wide text-teal-200/95 sm:text-base">
              <%= t("inicio.painel_casais.inscritos_label", count: @casais_inscritos_count) %>
            </span>
          </div>
        </div>
      <% end %>
    </div>
    <p class="mt-6 max-w-2xl text-base leading-relaxed text-stone-600 sm:text-lg">
      <%= t("inicio.subtitulo") %>
    </p>
    <div class="mt-10 flex flex-col gap-4 min-[400px]:flex-row min-[400px]:flex-wrap min-[400px]:items-center">
      <% painel_href =
           if user_signed_in? && !pode_gerir_painel?
             mobile_nav_cenaculo_href.presence || root_path
           elsif edicao_em_curso
             edicao_path(edicao_em_curso)
           else
             edicoes_path
           end %>
      <% painel_cta =
           if user_signed_in? && !pode_gerir_painel?
             t("inicio.cta_primario_participante")
           else
             t("inicio.cta_primario")
           end %>
      <%= link_to painel_href, class: "inline-flex min-h-[44px] w-full items-center justify-center rounded-full bg-stone-900 px-5 py-2.5 text-center text-sm font-medium text-white no-underline shadow-lg shadow-stone-900/10 ring-1 ring-stone-900/5 transition hover:bg-stone-800 min-[400px]:w-auto" do %>
        <%= painel_cta %>
      <% end %>
      <span class="text-center text-sm font-medium text-stone-500 min-[400px]:text-left"><%= t("inicio.cta_secundario") %></span>
    </div>

    <% if user_signed_in? && @edicao_painel.blank? %>
      <p class="mt-10 rounded-2xl border border-dashed border-stone-300 bg-stone-50/60 px-5 py-4 text-sm text-stone-600">
        <%= t("inicio.painel_casais.sem_edicao") %>
        <%= link_to t("inicio.painel_casais.ir_edicoes"), edicoes_path, class: "font-medium text-stone-900 underline underline-offset-2 hover:text-stone-700" %>.
      </p>
    <% end %>
  </div>
</section>

<%# Informações públicas do seminário (inscrições e logística) %>
<section class="border-t border-stone-200/80 bg-[#fafaf8] py-14 sm:py-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-stone-500"><%= t("inicio.evento_inscricoes.secao_titulo") %></p>
    <h2 class="mt-3 max-w-3xl font-display text-2xl tracking-tight text-stone-900 sm:text-3xl">
      <%= t("inicio.evento_inscricoes.titulo") %>
    </h2>
    <p class="mt-2 text-sm font-medium text-amber-900/90"><%= t("inicio.evento_inscricoes.periodo") %></p>
    <p class="mt-4 max-w-2xl text-sm leading-relaxed text-stone-600"><%= t("inicio.evento_inscricoes.linha_contexto") %></p>
    <p class="mt-3 max-w-2xl text-sm leading-relaxed text-stone-700"><%= t("inicio.evento_inscricoes.chamada") %></p>

    <div class="mt-10 max-w-3xl space-y-10">
        <div>
          <h3 class="font-display text-lg text-stone-900"><%= t("inicio.evento_inscricoes.local_titulo") %></h3>
          <p class="mt-2 text-sm font-medium text-stone-800"><%= t("inicio.evento_inscricoes.local_nome") %></p>
          <p class="mt-1 text-sm text-stone-600"><%= t("inicio.evento_inscricoes.local_endereco") %></p>
        </div>

        <div>
          <h3 class="font-display text-lg text-stone-900"><%= t("inicio.evento_inscricoes.horarios_titulo") %></h3>
          <ul class="mt-3 space-y-2 text-sm text-stone-700">
            <li><%= t("inicio.evento_inscricoes.horario_sexta") %></li>
            <li><%= t("inicio.evento_inscricoes.horario_sabado") %></li>
            <li><%= t("inicio.evento_inscricoes.horario_domingo") %></li>
          </ul>
        </div>

        <div>
          <h3 class="font-display text-lg text-stone-900"><%= t("inicio.evento_inscricoes.valor_titulo") %></h3>
          <p class="mt-2 text-sm font-medium text-stone-900"><%= t("inicio.evento_inscricoes.valor_texto") %></p>
          <p class="mt-2 text-xs text-stone-500"><%= t("inicio.evento_inscricoes.valor_nota") %></p>
        </div>

        <div>
          <h3 class="font-display text-lg text-stone-900"><%= t("inicio.evento_inscricoes.pagamento_titulo") %></h3>
          <ul class="mt-3 space-y-3 text-sm text-stone-700">
            <li>
              <span class="block text-stone-600"><%= t("inicio.evento_inscricoes.pix_texto") %></span>
              <code class="mt-1 inline-block rounded-lg bg-stone-200/70 px-2 py-1 font-mono text-sm text-stone-900"><%= t("inicio.evento_inscricoes.pix_chave") %></code>
            </li>
            <li><%= t("inicio.evento_inscricoes.cartao_texto") %></li>
          </ul>
        </div>

        <div>
          <h3 class="font-display text-lg text-stone-900"><%= t("inicio.evento_inscricoes.contato_titulo") %></h3>
          <p class="mt-2 text-sm text-stone-700">
            <%= t("inicio.evento_inscricoes.instagram_label") %> —
            <%= link_to t("inicio.evento_inscricoes.instagram_handle"), "https://www.instagram.com/comfacedecristo/",
                        target: "_blank", rel: "noopener noreferrer",
                        class: "font-medium text-stone-900 underline decoration-stone-400 underline-offset-4 hover:text-stone-700" %>
          </p>
        </div>
    </div>
  </div>
</section>

<section class="border-t border-stone-200/80 bg-white/60 py-16 backdrop-blur-sm sm:py-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      <% [
           [t("cards.edicoes.titulo"), t("cards.edicoes.texto"), "rounded-tl-xl"],
           [t("cards.equipes.titulo"), t("cards.equipes.texto"), ""],
           [t("cards.casais.titulo"), t("cards.casais.texto"), ""],
           [t("cards.cenaculos.titulo"), t("cards.cenaculos.texto"), "sm:rounded-tr-xl lg:rounded-tr-xl"]
         ].each_with_index do |(titulo, texto, corners), i| %>
        <article class="group rounded-2xl border border-stone-200/80 bg-gradient-to-br from-white to-stone-50/90 p-6 shadow-[0_1px_0_0_rgb(255_255_255/0.7)_inset] transition hover:border-stone-300/90 hover:shadow-md <%= corners %>">
          <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-stone-900/[0.04] ring-1 ring-stone-900/[0.06]">
            <span class="h-1 w-6 rounded-full bg-stone-400/80 transition group-hover:bg-stone-600"></span>
          </div>
          <h2 class="mt-5 font-display text-lg text-stone-900"><%= titulo %></h2>
          <p class="mt-2 text-sm leading-relaxed text-stone-600"><%= texto %></p>
        </article>
      <% end %>
    </div>
    <p class="mt-14 text-center text-xs text-stone-500"><%= t("inicio.pe") %></p>
  </div>
</section>
