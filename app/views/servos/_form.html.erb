<% conjuge_candidates =
     if pode_gerir_painel?
       Servo.where.not(id: [@servo.id].compact).order(:nome)
     else
       Servo.none
     end %>

<%= form_with model: @servo, class: "mt-8 max-w-xl space-y-6 sm:mt-10" do |f| %>
  <% if @servo.errors.any? %>
    <div class="rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-950">
      <p class="font-medium">Corrige os campos:</p>
      <ul class="mt-2 list-inside list-disc">
        <% @servo.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :nome, "Nome completo", class: "block text-sm font-medium text-stone-700" %>
    <%= f.text_field :nome,
                     class: "mt-2 min-h-[44px] w-full rounded-xl border border-stone-300 bg-white px-3 py-2 text-base text-stone-900 shadow-sm outline-none ring-stone-400/40 focus:border-stone-500 focus:ring-2 focus:ring-stone-500/20 sm:min-h-0 sm:text-sm",
                     autocomplete: "name",
                     autofocus: true %>
  </div>

  <% if pode_gerir_painel? %>
  <div>
    <%= f.label :papel, t("activerecord.attributes.servo.papel"), class: "block text-sm font-medium text-stone-700" %>
    <%= f.select :papel,
                 [[t("servos.papel.coordenacao"), Servo::PAPEL_COORDENACAO], [t("servos.papel.participante"), Servo::PAPEL_PARTICIPANTE]],
                 {},
                 class: "mt-2 min-h-[44px] w-full rounded-xl border border-stone-300 bg-white px-3 py-2 text-base text-stone-900 shadow-sm outline-none ring-stone-400/40 focus:border-stone-500 focus:ring-2 focus:ring-stone-500/20 sm:min-h-0 sm:text-sm" %>
    <p class="mt-1 text-xs text-stone-500"><%= t("servos.form_papel_dica") %></p>
  </div>

  <div class="grid gap-6 sm:grid-cols-2">
    <div>
      <%= f.label :sexo, "Sexo", class: "block text-sm font-medium text-stone-700" %>
      <%= f.select :sexo,
                   options_for_select(
                     [["(não informado)", ""]] + [["Masculino", "M"], ["Feminino", "F"]],
                     @servo.sexo
                   ),
                   {},
                   class: "mt-2 min-h-[44px] w-full rounded-xl border border-stone-300 bg-white px-3 py-2 text-base text-stone-900 shadow-sm outline-none ring-stone-400/40 focus:border-stone-500 focus:ring-2 focus:ring-stone-500/20 sm:min-h-0 sm:text-sm" %>
    </div>
    <div>
      <%= f.label :conjuge_id, "Cônjuge (opcional)", class: "block text-sm font-medium text-stone-700" %>
      <%= f.collection_select :conjuge_id, conjuge_candidates, :id, :nome,
                              { include_blank: "Sem cônjuge na lista" },
                              class: "mt-2 min-h-[44px] w-full rounded-xl border border-stone-300 bg-white px-3 py-2 text-base text-stone-900 shadow-sm outline-none ring-stone-400/40 focus:border-stone-500 focus:ring-2 focus:ring-stone-500/20 sm:min-h-0 sm:text-sm" %>
      <p class="mt-1 text-xs text-stone-500">Você pode apontar o cônjuge em um servo só ou em ambos, conforme sua organização dos dados.</p>
    </div>
  </div>

  <div>
    <%= f.label :email, "E-mail", class: "block text-sm font-medium text-stone-700" %>
    <%= f.email_field :email,
                      class: "mt-2 min-h-[44px] w-full rounded-xl border border-stone-300 bg-white px-3 py-2 text-base text-stone-900 shadow-sm outline-none ring-stone-400/40 focus:border-stone-500 focus:ring-2 focus:ring-stone-500/20 sm:min-h-0 sm:text-sm",
                      autocomplete: "email",
                      placeholder: "opcional" %>
  </div>

  <div>
    <%= f.label :telefone, "Telefone", class: "block text-sm font-medium text-stone-700" %>
    <%= f.telephone_field :telefone,
                          class: "mt-2 min-h-[44px] w-full rounded-xl border border-stone-300 bg-white px-3 py-2 text-base text-stone-900 shadow-sm outline-none ring-stone-400/40 focus:border-stone-500 focus:ring-2 focus:ring-stone-500/20 sm:min-h-0 sm:text-sm",
                          autocomplete: "tel",
                          placeholder: "opcional" %>
  </div>

  <section aria-labelledby="servo-acesso-titulo" class="rounded-2xl border border-stone-200/80 bg-stone-50/40 px-4 py-5 sm:px-5">
    <h2 id="servo-acesso-titulo" class="text-sm font-semibold text-stone-900"><%= t("servos.form_acesso_secao_titulo") %></h2>
    <p class="mt-2 text-xs leading-relaxed text-stone-600"><%= t("servos.form_acesso_explicacao") %></p>
    <% if @servo.user.present? %>
      <p class="mt-3 rounded-xl border border-emerald-200/70 bg-emerald-50/60 px-3 py-2.5 text-sm text-emerald-950">
        Este servo já tem acesso ao painel com <span class="font-mono font-medium tracking-tight text-emerald-900"><%= @servo.user.email %></span>.
        <span class="mt-1 block text-xs font-normal leading-relaxed text-emerald-900/95"><%= t("servos.form_instruction_password_existing_user") %></span>
      </p>
    <% else %>
      <div class="mt-4 flex gap-3 rounded-xl border border-stone-200/80 bg-white/90 px-3 py-3 sm:items-start">
        <%= f.check_box :dar_acesso,
                        class: "relative top-1 h-5 w-5 shrink-0 cursor-pointer rounded border-stone-300 text-stone-900 accent-stone-900 focus:ring-stone-500/30",
                        id: "servo_novo_dar_acesso" %>
        <%= f.label :dar_acesso,
                    t("servos.form_dar_acesso"),
                    class: "cursor-pointer select-none text-sm font-medium leading-snug text-stone-800",
                    for: "servo_novo_dar_acesso" %>
      </div>
    <% end %>
    <div class="mt-5 grid gap-4 sm:grid-cols-2">
      <div class="sm:col-span-1">
        <%= f.label :password, "senha (nova conta ou alteração)", class: "block text-sm font-medium text-stone-700" %>
        <%= f.password_field :password,
                             autocomplete: "new-password",
                             placeholder: t("servos.form_placeholder_senha"),
                             class: "mt-2 min-h-[44px] w-full rounded-xl border border-stone-300 bg-white px-3 py-2 text-base text-stone-900 shadow-sm outline-none ring-stone-400/40 focus:border-stone-500 focus:ring-2 focus:ring-stone-500/20 sm:min-h-0 sm:text-sm" %>
      </div>
      <div class="sm:col-span-1">
        <%= f.label :password_confirmation, "Confirmar senha", class: "block text-sm font-medium text-stone-700" %>
        <%= f.password_field :password_confirmation,
                             autocomplete: "new-password",
                             class: "mt-2 min-h-[44px] w-full rounded-xl border border-stone-300 bg-white px-3 py-2 text-base text-stone-900 shadow-sm outline-none ring-stone-400/40 focus:border-stone-500 focus:ring-2 focus:ring-stone-500/20 sm:min-h-0 sm:text-sm" %>
      </div>
    </div>
    <p class="mt-3 text-xs text-stone-500">Ao marcar dar acesso, o e‑mail do servo deve ser único no sistema.</p>
  </section>
  <% end %>

  <div class="flex flex-col gap-3 pt-4 sm:flex-row sm:flex-wrap">
    <% submit_label =
         if @servo.new_record?
           "Criar servo"
         elsif pode_gerir_painel?
           "Salvar alterações"
         else
           t("servos.submit_somente_nome")
         end %>
    <%= f.submit submit_label,
                 class: "min-h-[44px] w-full cursor-pointer rounded-full bg-stone-900 px-5 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-stone-800 sm:w-auto sm:min-h-0" %>
    <%= link_to "Cancelar", (@servo.new_record? ? servos_path : servo_path(@servo)),
                class: "inline-flex min-h-[44px] w-full items-center justify-center rounded-full border border-stone-300 bg-white px-5 py-2.5 text-center text-sm font-medium text-stone-800 hover:bg-stone-50 sm:w-auto sm:min-h-0" %>
  </div>
<% end %>
