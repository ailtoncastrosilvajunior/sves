<% content_for :title, t("cadastro_servos.page_title") %>

<% input_class = "mt-2 min-h-[48px] w-full rounded-xl border border-stone-300 bg-white px-3 py-2.5 text-base text-stone-900 shadow-sm outline-none ring-stone-400/40 focus:border-stone-500 focus:ring-2 focus:ring-stone-500/20 sm:min-h-0 sm:text-sm" %>
<% label_class = "block text-sm font-medium text-stone-700" %>
<% subsection_title_class = "text-sm font-semibold text-stone-900" %>

<div class="mx-auto flex min-h-[min(100dvh,48rem)] max-w-xl flex-col justify-center px-4 py-10 sm:px-6 sm:py-16">
  <div class="rounded-2xl border border-stone-200/80 bg-white/90 p-6 shadow-lg shadow-stone-900/5 ring-1 ring-stone-900/[0.02] sm:p-8">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-stone-500"><%= t("cadastro_servos.subtitulo") %></p>
    <h1 class="mt-4 font-display text-2xl tracking-tight text-stone-900 sm:text-3xl"><%= t("cadastro_servos.titulo") %></h1>
    <p class="mt-2 text-sm leading-relaxed text-stone-600"><%= t("cadastro_servos.intro") %></p>

    <%= form_with model: @form, url: cadastro_servo_path, class: "mt-8 space-y-8", html: { autocomplete: "on" } do |f| %>
      <% if @form.errors.any? %>
        <div class="rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-950">
          <ul class="mt-1 list-inside list-disc">
            <% @form.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :grupo_de_oracao, t("cadastro_servos.grupo_oracao_label"), class: label_class %>
        <%= f.text_field :grupo_de_oracao,
                         required: true,
                         autocomplete: "organization",
                         class: input_class %>
        <p class="mt-2 text-xs text-stone-500"><%= t("cadastro_servos.grupo_oracao_hint") %></p>
      </div>

      <div class="space-y-6 border-t border-stone-100 pt-7">
        <div>
          <h2 class="<%= subsection_title_class %>"><%= t("cadastro_servos.secao_dele") %></h2>
          <p class="mt-1 text-xs text-stone-500"><%= t("cadastro_servos.secao_dele_hint") %></p>
        </div>
        <%= f.fields_for :dele, @form.dele do |p| %>
          <div class="space-y-5">
            <div>
              <%= p.label :nome, t("cadastro_servos.nome_label"), class: label_class %>
              <%= p.text_field :nome, required: true, autocomplete: "name", class: input_class %>
            </div>
            <div>
              <%= p.label :email, t("cadastro_servos.email_label"), class: label_class %>
              <%= p.email_field :email, required: true, autocomplete: "email", class: input_class %>
            </div>
            <div>
              <%= p.label :telefone, t("cadastro_servos.telefone_label"), class: label_class %>
              <%= p.telephone_field :telefone, autocomplete: "tel", class: input_class %>
            </div>
            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <%= p.label :password, t("cadastro_servos.senha_label"), class: label_class %>
                <%= p.password_field :password, required: true, autocomplete: "new-password", class: input_class %>
              </div>
              <div>
                <%= p.label :password_confirmation, t("cadastro_servos.senha_confirmar_label"), class: label_class %>
                <%= p.password_field :password_confirmation, required: true, autocomplete: "new-password", class: input_class %>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <div class="space-y-6 border-t border-stone-100 pt-7">
        <div>
          <h2 class="<%= subsection_title_class %>"><%= t("cadastro_servos.secao_dela") %></h2>
          <p class="mt-1 text-xs text-stone-500"><%= t("cadastro_servos.secao_dela_hint") %></p>
        </div>
        <%= f.fields_for :dela, @form.dela do |p| %>
          <div class="space-y-5">
            <div>
              <%= p.label :nome, t("cadastro_servos.nome_label"), class: label_class %>
              <%= p.text_field :nome, required: true, autocomplete: "name", class: input_class %>
            </div>
            <div>
              <%= p.label :email, t("cadastro_servos.email_label"), class: label_class %>
              <%= p.email_field :email, required: true, autocomplete: "email", class: input_class %>
            </div>
            <div>
              <%= p.label :telefone, t("cadastro_servos.telefone_label"), class: label_class %>
              <%= p.telephone_field :telefone, autocomplete: "tel", class: input_class %>
            </div>
            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <%= p.label :password, t("cadastro_servos.senha_label"), class: label_class %>
                <%= p.password_field :password, required: true, autocomplete: "new-password", class: input_class %>
              </div>
              <div>
                <%= p.label :password_confirmation, t("cadastro_servos.senha_confirmar_label"), class: label_class %>
                <%= p.password_field :password_confirmation, required: true, autocomplete: "new-password", class: input_class %>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <div class="border-t border-stone-100 pt-2">
        <%= f.submit t("cadastro_servos.submit"),
                     class: "min-h-[48px] w-full cursor-pointer rounded-full bg-stone-900 px-5 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-stone-800 sm:min-h-[44px]" %>
      </div>
    <% end %>

    <p class="mt-8 border-t border-stone-100 pt-6 text-center text-sm text-stone-500">
      <%= link_to t("cadastro_servos.voltar_inicio"), root_path, class: "font-medium text-stone-800 underline-offset-4 hover:text-stone-950 hover:underline" %>
      <span class="mx-2 text-stone-300">·</span>
      <%= link_to t("cadastro_servos.ja_tem_login"), new_session_path, class: "font-medium text-stone-800 underline-offset-4 hover:text-stone-950 hover:underline" %>
    </p>
  </div>
</div>
