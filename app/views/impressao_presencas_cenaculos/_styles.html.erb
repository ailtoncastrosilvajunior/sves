    margin: 0;
    padding: 0;
  }

  .pastores-celula-impressao .past-line {
    margin: 0 0 3px;
    padding: 0;
  }

  .pastores-celula-impressao .past-line:last-child {
    margin-bottom: 0;
  }

  .pastores-celula-impressao .past-k {
