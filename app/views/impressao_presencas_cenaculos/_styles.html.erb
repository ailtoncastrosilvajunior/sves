    min-width: 1.1em;
    font-weight: 800;
    color: var(--accent);
  }

  .vazio .vazio-cenaculo-nome {
    font-weight: 700;
    color: #57534e;
  }

  table.grid-presenca {
    width: 100%;
    border-collapse: collapse;
    font-size: 8px;
    table-layout: fixed;
    margin-top: 4px;
    page-break-inside: auto;
  }

  table.grid-presenca th,
  table.grid-presenca td {
    border: 1px solid var(--line);
    padding: 3px 4px;
    vertical-align: middle;
  }

  table.grid-presenca thead th {
    background: var(--thead);
    font-weight: 700;
    text-align: center;
    color: #44403c;
    font-size: 7px;
    line-height: 1.2;
  }

  table.grid-presenca thead th.col-cenaculo-merge,
  table.grid-presenca thead th.col-pastores-merge,
  table.grid-presenca thead th.col-casal-par {
    text-align: left;
  }

  table.grid-presenca thead th.col-reu-sub {
    font-size: 6px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--muted);
    padding: 2px 3px;
    line-height: 1.15;
  }

  table.grid-presenca th.col-reu {
    word-break: break-word;
    hyphens: auto;
  }

  table.grid-presenca td.col-casal-par {
    text-align: left;
    vertical-align: middle;
  }

  .nome-chamado-par {
    display: block;
    font-weight: 600;
    font-size: 7.5px;
    line-height: 1.3;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .nome-chamado-sep {
    color: #a8a29e;
    font-weight: 500;
    padding: 0 0.15em;
  }

  .nome-chamado-ela {
    color: #1c1917;
  }

  table.grid-presenca td.cel-pres {
    text-align: center;
  }

  table.grid-presenca td.cel-pres-dupla {
    padding: 4px 2px;
  }

  .cel-dupla-presenca {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    font-size: 10px;
    font-weight: 800;
    line-height: 1;
    white-space: nowrap;
  }

  .pres-marca-sep {
    color: #a8a29e;
    font-weight: 600;
    font-size: 9px;
    padding: 0 0.2em;
    user-select: none;
  }

  .pres-marca-ele {
    color: #1e40af;
  }

  .pres-marca-ela {
    color: #9d174d;
  }

  .vazio {
    margin: 12px 0;
    padding: 8px;
    font-size: 9px;
    color: var(--muted);
    text-align: center;
    border: 1px dashed var(--line);
    border-radius: 4px;
  }

  @media print {
    body.impressao-presencas-cenaculos {
      padding: 0;
      background: #fff;
    }

    .sheet {
      box-shadow: none;
      border-radius: 0;
      max-width: none;
      padding: 0;
    }

    .no-print { display: none !important; }

    .pres-marca-ele,
    .pres-marca-ela {
      color: var(--ink);
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    @page {
      size: A4 landscape;
      margin: 8mm;
    }
  }
</style>
