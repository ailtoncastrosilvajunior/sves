<style>
  :root {
    --ink: #1c1917;
    --muted: #57534e;
    --line: #d6d3d1;
    --thead: #f5f5f4;
    --accent: #0f766e;
  }

  * { box-sizing: border-box; }

  body.impressao-presencas-cenaculos {
    margin: 0;
    padding: 1rem;
    font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    font-size: 10px;
    line-height: 1.35;
    color: var(--ink);
    background: #fafaf9;
  }

  .toolbar-impressao {
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    max-width: 297mm;
    margin: 0 auto 1rem;
    padding: 0.65rem 1rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
    box-shadow: 0 1px 3px rgb(0 0 0 / 0.06);
  }

  .toolbar-impressao a {
    color: var(--accent);
    font-weight: 600;
    font-size: 13px;
    text-decoration: none;
  }

  .toolbar-impressao a:hover { text-decoration: underline; }

  .toolbar-impressao button {
    cursor: pointer;
    border: none;
    border-radius: 999px;
    padding: 0.5rem 1rem;
    font-size: 13px;
    font-weight: 600;
    color: #fff;
    background: linear-gradient(to right, #0d9488, #0f766e);
    box-shadow: 0 2px 8px rgb(15 118 110 / 0.35);
  }

  .sheet {
    max-width: 297mm;
    margin: 0 auto;
    background: #fff;
    padding: 8mm 10mm;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
    border-radius: 4px;
  }

  header.doc-head {
    text-align: center;
    margin-bottom: 6px;
    padding-bottom: 6px;
    border-bottom: 2px solid var(--ink);
  }

  header.doc-head h1 {
    margin: 0;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  header.doc-head .sub {
    margin: 4px 0 0;
    font-size: 8px;
    color: var(--muted);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  header.doc-head .edicao {
    margin-top: 4px;
    font-size: 10px;
    font-weight: 700;
    color: var(--accent);
  }

  .legenda-simbolos {
    margin: 8px 0 10px;
    padding: 6px 8px;
    font-size: 8px;
    line-height: 1.45;
    color: var(--muted);
    background: var(--thead);
    border: 1px solid var(--line);
    border-radius: 4px;
  }

  .legenda-simbolos strong { color: var(--ink); }

  .bloco-cenaculo {
    margin-top: 12px;
    page-break-inside: auto;
  }

  .bloco-cenaculo:first-of-type {
    margin-top: 8px;
  }

  table.grid-presenca thead th.col-cenaculo-merge {
    width: 11%;
    text-align: left;
    vertical-align: bottom;
    font-size: 7px;
    line-height: 1.2;
  }

  table.grid-presenca thead th.col-pastores-merge {
    width: 17%;
    text-align: left;
    vertical-align: bottom;
    font-size: 7px;
    line-height: 1.2;
  }

  table.grid-presenca th.col-casal-par {
    width: 16%;
    text-align: left;
    vertical-align: middle;
    font-size: 8px;
  }

  table.grid-presenca td.cel-cenaculo-merge {
    vertical-align: top;
    text-align: left;
    font-weight: 800;
    font-size: 8px;
    line-height: 1.25;
    letter-spacing: 0.02em;
    background: #fafaf9;
    word-break: break-word;
  }

  table.grid-presenca td.cel-pastores-merge {
    vertical-align: top;
    text-align: left;
    font-size: 6.5px;
    line-height: 1.3;
    color: #44403c;
    background: #fafaf9;
    word-break: break-word;
  }

