<%= form_with model: [edicao, casal], class: "mt-8 max-w-3xl space-y-8 sm:mt-10" do |f| %>
  <% if casal.errors.any? %>
    <div class="rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-950">
      <p class="font-medium"><%= t("casais_views.cadastro_secretaria.erros_titulo") %></p>
      <ul class="mt-2 list-inside list-disc">
        <% casal.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <fieldset class="space-y-6 rounded-2xl border border-stone-200/80 bg-white px-4 py-5 shadow-sm sm:px-5">
    <legend class="px-1 text-sm font-semibold text-stone-900"><%= t("casais_views.cadastro_secretaria.secao_participantes") %></legend>

    <div class="grid gap-6 sm:grid-cols-2">
      <div class="space-y-4 rounded-xl border border-stone-200/80 bg-stone-50/50 px-4 py-4 ring-1 ring-stone-900/[0.03] sm:px-5">
        <h3 class="text-xs font-semibold uppercase tracking-wide text-teal-900/90"><%= t("casais_views.cadastro_secretaria.bloco_ele") %></h3>
        <div>
          <%= f.label :nome_completo_ele, t("activerecord.attributes.casal.nome_completo_ele"), class: "block text-sm font-medium text-stone-700" %>
          <%= f.text_field :nome_completo_ele,
                           required: true,
                           class: "mt-2 min-h-[44px] w-full rounded-xl border border-stone-300 bg-white px-3 py-2 text-base text-stone-900 shadow-sm outline-none ring-stone-400/40 focus:border-stone-500 focus:ring-2 focus:ring-stone-500/20 sm:min-h-0 sm:text-sm",
                           autocomplete: "given-name" %>
          <p class="mt-1 text-xs text-stone-500"><%= t("casais_views.cadastro_secretaria.dica_nomes_maiusculas") %></p>
        </div>
        <div>
          <%= f.label :apelido_ele, t("activerecord.attributes.casal.apelido_ele"), class: "block text-sm font-medium text-stone-700" %>
          <%= f.text_field :apelido_ele,
                           class: "mt-2 min-h-[44px] w-full rounded-xl border border-stone-300 bg-white px-3 py-2 text-base text-stone-900 shadow-sm outline-none ring-stone-400/40 focus:border-stone-500 focus:ring-2 focus:ring-stone-500/20 sm:min-h-0 sm:text-sm" %>
        </div>
        <div>
          <%= f.label :data_nascimento_ele, t("activerecord.attributes.casal.data_nascimento_ele"), class: "block text-sm font-medium text-stone-700" %>
          <%= f.date_field :data_nascimento_ele,
                           class: "mt-2 min-h-[44px] w-full rounded-xl border border-stone-300 bg-white px-3 py-2 text-base text-stone-900 shadow-sm outline-none ring-stone-400/40 focus:border-stone-500 focus:ring-2 focus:ring-stone-500/20 sm:min-h-0 sm:text-sm" %>
        </div>
      </div>

      <div class="space-y-4 rounded-xl border border-stone-200/80 bg-stone-50/50 px-4 py-4 ring-1 ring-stone-900/[0.03] sm:px-5">
        <h3 class="text-xs font-semibold uppercase tracking-wide text-teal-900/90"><%= t("casais_views.cadastro_secretaria.bloco_ela") %></h3>
        <div>
          <%= f.label :nome_completo_ela, t("activerecord.attributes.casal.nome_completo_ela"), class: "block text-sm font-medium text-stone-700" %>
          <%= f.text_field :nome_completo_ela,
                           required: true,
                           class: "mt-2 min-h-[44px] w-full rounded-xl border border-stone-300 bg-white px-3 py-2 text-base text-stone-900 shadow-sm outline-none ring-stone-400/40 focus:border-stone-500 focus:ring-2 focus:ring-stone-500/20 sm:min-h-0 sm:text-sm",
                           autocomplete: "additional-name" %>
        </div>
        <div>
          <%= f.label :apelido_ela, t("activerecord.attributes.casal.apelido_ela"), class: "block text-sm font-medium text-stone-700" %>
          <%= f.text_field :apelido_ela,
                           class: "mt-2 min-h-[44px] w-full rounded-xl border border-stone-300 bg-white px-3 py-2 text-base text-stone-900 shadow-sm outline-none ring-stone-400/40 focus:border-stone-500 focus:ring-2 focus:ring-stone-500/20 sm:min-h-0 sm:text-sm" %>
        </div>
        <div>
          <%= f.label :data_nascimento_ela, t("activerecord.attributes.casal.data_nascimento_ela"), class: "block text-sm font-medium text-stone-700" %>
          <%= f.date_field :data_nascimento_ela,
                           class: "mt-2 min-h-[44px] w-full rounded-xl border border-stone-300 bg-white px-3 py-2 text-base text-stone-900 shadow-sm outline-none ring-stone-400/40 focus:border-stone-500 focus:ring-2 focus:ring-stone-500/20 sm:min-h-0 sm:text-sm" %>
        </div>
      </div>
    </div>
  </fieldset>

  <fieldset class="space-y-4 rounded-2xl border border-stone-200/80 bg-white px-4 py-5 shadow-sm sm:px-5">
    <legend class="px-1 text-sm font-semibold text-stone-900"><%= t("casais_views.cadastro_secretaria.secao_registo_secretaria") %></legend>
    <div>
      <%= f.label :inscrito_em, t("activerecord.attributes.casal.inscrito_em"), class: "block text-sm font-medium text-stone-700" %>
      <%= f.datetime_local_field :inscrito_em,
                                 class: "mt-2 min-h-[44px] w-full max-w-md rounded-xl border border-stone-300 bg-white px-3 py-2 text-base text-stone-900 shadow-sm outline-none ring-stone-400/40 focus:border-stone-500 focus:ring-2 focus:ring-stone-500/20 sm:min-h-0 sm:text-sm" %>
      <p class="mt-1 text-xs text-stone-500"><%= t("casais_views.cadastro_secretaria.dica_inscrito_em") %></p>
    </div>
  </fieldset>

  <fieldset class="space-y-5 rounded-2xl border border-stone-200/80 bg-white px-4 py-5 shadow-sm sm:px-5">
    <legend class="px-1 text-sm font-semibold text-stone-900"><%= t("casais_views.cadastro_secretaria.secao_contato") %></legend>
    <div>
      <%= f.label :email_contato, t("activerecord.attributes.casal.email_contato"), class: "block text-sm font-medium text-stone-700" %>
      <%= f.email_field :email_contato,
                        class: "mt-2 min-h-[44px] w-full rounded-xl border border-stone-300 bg-white px-3 py-2 text-base text-stone-900 shadow-sm outline-none ring-stone-400/40 focus:border-stone-500 focus:ring-2 focus:ring-stone-500/20 sm:min-h-0 sm:text-sm",
                        autocomplete: "email" %>
    </div>
    <div>
      <%= f.label :telefones_contato, t("activerecord.attributes.casal.telefones_contato"), class: "block text-sm font-medium text-stone-700" %>
      <%= f.text_area :telefones_contato,
                      rows: 2,
                      class: "mt-2 w-full rounded-xl border border-stone-300 bg-white px-3 py-2 text-base text-stone-900 shadow-sm outline-none ring-stone-400/40 focus:border-stone-500 focus:ring-2 focus:ring-stone-500/20 sm:text-sm" %>
    </div>
    <div>
      <%= f.label :endereco, t("activerecord.attributes.casal.endereco"), class: "block text-sm font-medium text-stone-700" %>
      <%= f.text_area :endereco,
                      rows: 3,
                      class: "mt-2 w-full rounded-xl border border-stone-300 bg-white px-3 py-2 text-base text-stone-900 shadow-sm outline-none ring-stone-400/40 focus:border-stone-500 focus:ring-2 focus:ring-stone-500/20 sm:text-sm" %>
    </div>
  </fieldset>

  <fieldset class="space-y-5 rounded-2xl border border-stone-200/80 bg-white px-4 py-5 shadow-sm sm:px-5">
    <legend class="px-1 text-sm font-semibold text-stone-900"><%= t("casais_views.cadastro_secretaria.secao_opcional") %></legend>
    <div>
      <%= f.label :observacoes, t("activerecord.attributes.casal.observacoes"), class: "block text-sm font-medium text-stone-700" %>
      <%= f.text_area :observacoes,
                      rows: 3,
                      class: "mt-2 w-full rounded-xl border border-stone-300 bg-white px-3 py-2 text-base text-stone-900 shadow-sm outline-none ring-stone-400/40 focus:border-stone-500 focus:ring-2 focus:ring-stone-500/20 sm:text-sm" %>
      <p class="mt-1 text-xs text-stone-500"><%= t("casais_views.cadastro_secretaria.dica_observacoes") %></p>
    </div>
  </fieldset>

  <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
    <%= f.submit t("casais_views.cadastro_secretaria.submit"),
                 class: "inline-flex min-h-[44px] w-full cursor-pointer items-center justify-center rounded-full border border-stone-800 bg-stone-900 px-6 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-stone-800 sm:w-auto" %>
    <%= link_to t("casais_views.cadastro_secretaria.cancelar"), edicao_casais_path(edicao),
                class: "inline-flex min-h-[44px] w-full items-center justify-center rounded-full border border-stone-300 bg-white px-6 py-2.5 text-center text-sm font-medium text-stone-800 shadow-sm hover:bg-stone-50 sm:w-auto" %>
  </div>
<% end %>
