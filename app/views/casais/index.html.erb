<% content_for :title, "Casais · #{@edicao.rotulo} · SVES" %>
<% resumida = @visualizacao_casais == "resumida" %>
<% nomes_chamados = @visualizacao_casais == "nomes_chamados" %>
<% completa = @visualizacao_casais == "completa" %>

<div class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-10 lg:px-8">
  <%= render "application/back_button", href: edicao_path(@edicao), label: "Edição" %>
  <div class="min-w-0">
    <p class="text-xs font-semibold uppercase tracking-wider text-stone-500">Edição <%= @edicao.rotulo %></p>
    <h1 class="mt-2 font-display text-2xl tracking-tight text-stone-900 sm:text-3xl">Casais inscritos</h1>
    <p class="mt-2 text-sm text-stone-600">
      <% if @casais.size == 1 %>
        <%= t("casais_views.index.resumo_um", count: @casais.size) %>
      <% else %>
        <%= t("casais_views.index.resumo_varios", count: @casais.size) %>
      <% end %>
      Dados vindos do CSV/Google Forms ficam atualizados a cada nova importação.
    </p>
  </div>

  <% if @casais.any? %>
    <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:flex-wrap sm:items-center sm:justify-between">
      <p class="text-sm font-medium text-stone-700">Apresentação da lista</p>
      <div class="flex flex-col gap-2 sm:flex-row sm:flex-wrap sm:items-center">
        <%= link_to t("casais_views.cadastro_secretaria.titulo"), new_edicao_casal_path(@edicao),
                    class: "inline-flex min-h-[44px] w-full items-center justify-center rounded-full border border-teal-600/50 bg-teal-50/90 px-5 py-2 text-center text-sm font-medium text-teal-950 shadow-sm hover:border-teal-600 hover:bg-teal-50 sm:w-auto sm:min-h-0" %>
        <nav class="inline-flex rounded-full border border-stone-200 bg-stone-100/80 p-1 text-sm font-medium shadow-inner"
             role="group"
             aria-label="Tipo de lista de casais">
        <%= link_to edicao_casais_path(@edicao, v: "resumida"),
                    class: "rounded-full px-4 py-2 transition #{resumida ? "bg-stone-900 text-white shadow-sm" : "text-stone-600 hover:bg-stone-200/70 hover:text-stone-900"}" do %>
          Resumida
        <% end %>
        <%= link_to edicao_casais_path(@edicao, v: "nomes_chamados"),
                    class: "rounded-full px-4 py-2 transition #{nomes_chamados ? "bg-stone-900 text-white shadow-sm" : "text-stone-600 hover:bg-stone-200/70 hover:text-stone-900"}" do %>
          <%= t("casais_views.index.tipo_lista_nomes_chamados") %>
        <% end %>
        <%= link_to edicao_casais_path(@edicao, v: "completa"),
                    class: "rounded-full px-4 py-2 transition #{completa ? "bg-stone-900 text-white shadow-sm" : "text-stone-600 hover:bg-stone-200/70 hover:text-stone-900"}" do %>
            Ficha completa
        <% end %>
        </nav>
      </div>
    </div>

    <div data-controller="distribuicao-casais">
      <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
        <div class="min-w-0 flex-1">
          <%= label_tag dom_id(@edicao, :busca_casais_lista),
                        t("casais_views.index.busca.label"),
                        class: "sr-only" %>
          <%= text_field_tag :busca_casais_lista,
                             "",
                             id: dom_id(@edicao, :busca_casais_lista),
                             autocomplete: "off",
                             placeholder: t("casais_views.index.busca.placeholder"),
                             data: {
                               distribuicao_casais_target: "campoBusca",
                               action: "input->distribuicao-casais#atualizarFiltragem",
                             },
                             class: "min-h-[48px] w-full rounded-xl border border-stone-300 bg-white px-4 py-2.5 text-sm text-stone-900 shadow-inner outline-none ring-stone-400/30 placeholder:text-stone-400 focus:border-teal-600/60 focus:ring-2 focus:ring-teal-500/20 sm:min-h-10" %>
        </div>
        <%= button_tag t("casais_views.index.busca.limpar"),
                       type: "button",
                       data: { action: "click->distribuicao-casais#limparCampoBusca" },
                       class: "inline-flex min-h-[48px] cursor-pointer items-center justify-center rounded-full border border-stone-300 bg-white px-5 py-2 text-sm font-medium text-stone-800 shadow-sm transition hover:bg-stone-50 sm:min-h-10" %>
      </div>

      <p data-distribuicao-casais-target="semResultados"
         class="mt-4 hidden rounded-xl border border-amber-200/90 bg-amber-50 px-4 py-3 text-sm leading-relaxed text-amber-950"
         role="status">
        <%= t("casais_views.index.busca.sem_resultados") %>
      </p>

      <p role="status" aria-live="polite"
         data-distribuicao-casais-target="resultadoFiltragem"
         class="mt-3 hidden rounded-lg bg-teal-100/70 px-3 py-2 text-sm font-medium text-teal-950"></p>

    <% if resumida %>
      <div class="mt-8 overflow-hidden rounded-2xl border border-stone-200/80 bg-white shadow-sm">
        <div class="divide-y divide-stone-200/80">
          <% @casais.each do |casal| %>
            <div class="flex flex-col gap-2 border-l-[3px] border-transparent px-5 py-4 transition-colors duration-200 ease-out hover:border-teal-700/45 hover:bg-teal-50/35 sm:flex-row sm:flex-wrap sm:items-start sm:justify-between sm:gap-4"
                 data-distribuicao-casais-target="cartao"
                 data-busca="<%= texto_busca_distribuicao_casal(casal) %>">
              <div class="min-w-0">
                <p class="font-medium text-stone-900">
                  <span><%= casal.nome_completo_ele.presence || "—" %></span>
                  <span class="text-stone-400"> e </span>
                  <span><%= casal.nome_completo_ela.presence || "—" %></span>
                </p>
                <% tem_apelido = casal.apelido_ele.present? || casal.apelido_ela.present? %>
                <% if tem_apelido %>
                  <p class="mt-1.5 flex flex-wrap gap-x-2 gap-y-0.5 text-sm">
                    <% if casal.apelido_ele.present? %>
                      <span><span class="text-teal-600/85">Ele ·</span> <span class="font-medium tracking-tight text-teal-900 uppercase"><%= casal.apelido_ele.strip %></span></span>
                    <% end %>
                    <% if casal.apelido_ele.present? && casal.apelido_ela.present? %>
                      <span class="text-teal-500/55" aria-hidden="true">·</span>
                    <% end %>
                    <% if casal.apelido_ela.present? %>
                      <span><span class="text-teal-600/85">Ela ·</span> <span class="font-medium tracking-tight text-teal-900 uppercase"><%= casal.apelido_ela.strip %></span></span>
                    <% end %>
                  </p>
                <% end %>
                <% if casal.telefones_contato.present? %>
                  <p class="mt-1 text-sm text-stone-600 break-words"><%= casal.telefones_contato %></p>
                <% end %>
                <% if casal.email_contato.present? %>
                  <%= mail_to casal.email_contato, casal.email_contato,
                              class: "mt-1 inline-block text-sm text-stone-700 underline underline-offset-2 hover:text-stone-900" %>
                <% end %>
                <p class="mt-2 text-xs text-stone-500">
                  Fonte: <%= t("casais_views.fontes.#{casal.fonte_importacao}", default: casal.fonte_importacao.to_s.titleize) %>
                </p>
                <%= render "casais/cenaculo_linha_casal", casal: casal, edicao: @edicao %>
              </div>
              <div class="shrink-0 flex flex-col items-end gap-3 text-right">
                <%= link_to t("casais_views.alterar_casal.botao_lista"), edit_edicao_casal_path(@edicao, casal),
                            class: "inline-flex min-h-[44px] items-center justify-center rounded-full border border-stone-300 bg-white px-4 py-2 text-sm font-medium text-stone-800 shadow-sm hover:bg-stone-50 sm:min-h-0" %>
                <% if casal.inscrito_em.present? %>
                  <p class="text-xs font-medium uppercase tracking-wide text-stone-500">Inscrito em</p>
                  <time class="mt-0.5 block text-sm text-stone-800" datetime="<%= casal.inscrito_em&.iso8601 %>">
                    <%= l(casal.inscrito_em, format: :short) %>
                  </time>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% elsif nomes_chamados %>
      <p class="mt-4 max-w-prose text-sm leading-relaxed text-stone-600"><%= t("casais_views.index.nomes_chamados_intro") %></p>
      <div class="mt-6 overflow-hidden rounded-2xl border border-stone-200/80 bg-white shadow-sm">
        <div class="divide-y divide-stone-200/80">
          <% @casais.each do |casal| %>
            <div class="border-l-[3px] border-transparent px-5 py-4 transition-colors duration-200 ease-out hover:border-teal-700/45 hover:bg-teal-50/35"
                 data-distribuicao-casais-target="cartao"
                 data-busca="<%= texto_busca_distribuicao_casal(casal) %>">
              <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between sm:gap-4">
                <div class="grid min-w-0 flex-1 gap-4 sm:grid-cols-2 sm:gap-8">
                  <div class="min-w-0 space-y-1">
                    <p class="text-[0.65rem] font-semibold uppercase tracking-wide text-stone-500"><%= t("casais_views.index.rotulo_esposo") %></p>
                    <% apelido_ele = (casal.apelido_ele&.strip).presence %>
                    <% nome_ele = casal.nome_completo_ele.presence || "—" %>
                    <% if apelido_ele %>
                      <p class="text-lg font-semibold uppercase leading-snug tracking-tight text-teal-950 sm:text-xl"><%= apelido_ele %></p>
                      <p class="mt-0.5 text-sm leading-snug text-stone-500"><%= nome_ele %></p>
                    <% else %>
                      <p class="text-lg font-semibold leading-snug tracking-tight text-stone-900 sm:text-xl"><%= nome_ele %></p>
                    <% end %>
                  </div>
                  <div class="min-w-0 space-y-1">
                    <p class="text-[0.65rem] font-semibold uppercase tracking-wide text-stone-500"><%= t("casais_views.index.rotulo_esposa") %></p>
                    <% apelido_ela = (casal.apelido_ela&.strip).presence %>
                    <% nome_ela = casal.nome_completo_ela.presence || "—" %>
                    <% if apelido_ela %>
                      <p class="text-lg font-semibold uppercase leading-snug tracking-tight text-teal-950 sm:text-xl"><%= apelido_ela %></p>
                      <p class="mt-0.5 text-sm leading-snug text-stone-500"><%= nome_ela %></p>
                    <% else %>
                      <p class="text-lg font-semibold leading-snug tracking-tight text-stone-900 sm:text-xl"><%= nome_ela %></p>
                    <% end %>
                  </div>
                </div>
                <%= link_to t("casais_views.alterar_casal.botao_lista"), edit_edicao_casal_path(@edicao, casal),
                            class: "inline-flex min-h-[44px] shrink-0 items-center justify-center self-start rounded-full border border-stone-300 bg-white px-4 py-2 text-sm font-medium text-stone-800 shadow-sm hover:bg-stone-50 sm:self-auto" %>
              </div>
              <%= render "casais/cenaculo_linha_casal", casal: casal, edicao: @edicao %>
            </div>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="mt-8 rounded-2xl border border-stone-200/80 bg-gradient-to-b from-stone-50/80 to-white px-4 py-5 shadow-sm ring-1 ring-stone-200/60 sm:px-6">
        <div class="min-w-0">
          <p class="text-sm font-semibold text-stone-900">Ficha completa · todos os dados da inscrição</p>
        </div>

        <div class="mt-5 max-h-[min(70vh,44rem)] min-w-0 w-full overflow-y-auto overflow-x-hidden rounded-2xl border border-stone-200/70 bg-white/90 pr-2 shadow-inner">
          <ul class="space-y-5 p-4 sm:p-5">
            <% @casais.each do |casal| %>
              <%= tag.li class: "min-w-0 rounded-2xl border border-stone-200 bg-white px-5 py-4 shadow-sm transition hover:border-teal-300/55 hover:bg-teal-50/25",
                           data: {
                             distribuicao_casais_target: "cartao",
                             busca: texto_busca_distribuicao_casal(casal),
                           } do %>
                <%= render "casais/detalhe_casal_completo", casal: casal, edicao: @edicao, mostrar_alterar_casal: true %>
              <% end %>
            <% end %>
          </ul>
        </div>
      </div>
    <% end %>
    </div>
  <% else %>
    <p class="mt-10 rounded-2xl border border-dashed border-stone-300 bg-stone-50/50 px-5 py-8 text-center text-sm text-stone-600">
      Ainda não há casais nesta edição — importe o CSV na edição, aguarde a planilha ou
      <%= link_to "registe um casal da secretaria", new_edicao_casal_path(@edicao), class: "font-medium text-teal-800 underline underline-offset-2 hover:text-teal-950" %>.
    </p>
  <% end %>
</div>
