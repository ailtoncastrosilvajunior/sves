<% content_for :title, "#{t("casais_views.cadastro_secretaria.titulo")} · #{@edicao.rotulo} · SVES" %>

<div class="mx-auto max-w-3xl px-4 py-8 sm:px-6 sm:py-10 lg:px-8">
  <%= render "application/back_button", href: edicao_casais_path(@edicao), label: t("casais_views.cadastro_secretaria.voltar_lista") %>
  <div class="mt-6 min-w-0">
    <p class="text-xs font-semibold uppercase tracking-wider text-stone-500">Edição <%= @edicao.rotulo %></p>
    <h1 class="mt-2 font-display text-2xl tracking-tight text-stone-900 sm:text-3xl"><%= t("casais_views.cadastro_secretaria.titulo") %></h1>
    <p class="mt-2 max-w-prose text-sm leading-relaxed text-stone-600"><%= t("casais_views.cadastro_secretaria.subtitulo") %></p>
  </div>

  <%= render "form_cadastro_secretaria", casal: @casal, edicao: @edicao %>
</div>
