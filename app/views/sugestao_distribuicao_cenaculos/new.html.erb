<% content_for :title, t("cenaculos.distribuicao_sugestao.titulo_html", edicao: @edicao.rotulo) %>

<div class="mx-auto max-w-4xl px-4 py-8 sm:px-6 sm:py-10 lg:px-8">
  <%= render "application/back_button", href: edicao_path(@edicao), label: t("cenaculos.distribuicao_sugestao.voltar_edicao") %>
  <header class="mt-4">
    <p class="text-xs font-semibold uppercase tracking-wider text-stone-500"><%= t("cenaculos.distribuicao_sugestao.etiqueta_secao") %></p>
    <h1 class="mt-2 font-display text-2xl tracking-tight text-stone-900 sm:text-3xl"><%= t("cenaculos.distribuicao_sugestao.heading") %></h1>
    <p class="mt-3 text-sm leading-relaxed text-stone-600"><%= t("cenaculos.distribuicao_sugestao.intro") %></p>
    <p class="mt-2 text-sm text-stone-700"><%= t("cenaculos.distribuicao_sugestao.casais_no_escopo_html", count: @contagem_escopo) %></p>
  </header>

  <%= form_with url: edicao_distribuicao_cenaculos_sugestao_envio_path(@edicao), method: :post, html: { class: "mt-8 space-y-6", data: { turbo: false } } do %>
    <div class="flex flex-col gap-2 rounded-2xl border border-stone-200/80 bg-stone-50/50 px-4 py-4">
      <%= label_tag :somente_sem_cenaculo, class: "flex cursor-pointer gap-3 text-sm font-medium text-stone-800" do %>
        <%= hidden_field_tag :somente_sem_cenaculo, "0", id: nil %>
        <%= check_box_tag :somente_sem_cenaculo, "1", @somente_sem_cenaculo,
                          class: "mt-1 h-4 w-4 rounded border-stone-300 text-stone-900" %>
        <span><%= t("cenaculos.distribuicao_sugestao.apenas_livres_label") %></span>
      <% end %>
      <p class="pl-7 text-xs leading-relaxed text-stone-600"><%= t("cenaculos.distribuicao_sugestao.apenas_livres_ajuda") %></p>
      <div class="pl-7 pt-2 text-xs text-stone-600">
        <%= link_to t("cenaculos.distribuicao_sugestao.ver_sem_filtro"), edicao_distribuicao_cenaculos_sugestao_path(@edicao, somente_sem_cenaculo: 0), class: "font-medium underline-offset-4 hover:text-stone-900 hover:underline" %>
        ·
        <%= link_to t("cenaculos.distribuicao_sugestao.ver_so_livres"), edicao_distribuicao_cenaculos_sugestao_path(@edicao, somente_sem_cenaculo: 1), class: "font-medium underline-offset-4 hover:text-stone-900 hover:underline" %>
      </div>
    </div>
    <div>
      <%= label_tag :casais_por_grupo, t("cenaculos.distribuicao_sugestao.casais_por_grupo_label"), class: "block text-sm font-medium text-stone-700" %>
      <%= number_field_tag :casais_por_grupo, @casais_por_grupo_prefill, min: 2, max: [@contagem_escopo, 2].max, required: true,
                             class: "mt-2 block w-full max-w-xs rounded-xl border border-stone-200 px-3 py-2 text-stone-900 shadow-sm focus:border-stone-400 focus:outline-none focus:ring-1 focus:ring-stone-300" %>
      <p class="mt-1 text-xs text-stone-500"><%= t("cenaculos.distribuicao_sugestao.casais_por_grupo_dica") %></p>
    </div>
    <div>
      <%= label_tag :semilla, t("cenaculos.distribuicao_sugestao.semilla_label"), class: "block text-sm font-medium text-stone-700" %>
      <%= text_field_tag :semilla, @semilla_manual, placeholder: t("cenaculos.distribuicao_sugestao.semilla_placeholder"),
                         class: "mt-2 block w-full max-w-md rounded-xl border border-stone-200 px-3 py-2 text-stone-900 shadow-sm focus:border-stone-400 focus:outline-none focus:ring-1 focus:ring-stone-300" %>
      <p class="mt-1 text-xs text-stone-500"><%= t("cenaculos.distribuicao_sugestao.semilla_dica") %></p>
    </div>
    <div>
      <%= label_tag :texto_regra, t("cenaculos.distribuicao_sugestao.prompt_label"), class: "block text-sm font-medium text-stone-700" %>
      <p class="mt-1 text-xs text-stone-500"><%= t("cenaculos.distribuicao_sugestao.prompt_ajuda") %></p>
      <%= text_area_tag :texto_regra, @texto_regra, rows: 14,
                        class: "mt-3 block w-full rounded-2xl border border-stone-200 bg-white px-3 py-3 font-mono text-sm text-stone-900 shadow-inner focus:border-stone-400 focus:outline-none focus:ring-1 focus:ring-stone-300" %>
    </div>
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
      <%= submit_tag t("cenaculos.distribuicao_sugestao.gerar_documento"),
                     class: "inline-flex min-h-[44px] cursor-pointer items-center justify-center rounded-full bg-stone-900 px-6 py-2.5 text-sm font-medium text-white shadow-sm ring-1 ring-stone-900/10 transition hover:bg-stone-800" %>
      <p class="text-xs leading-relaxed text-stone-500"><%= t("cenaculos.distribuicao_sugestao.avisos_na_geracao") %></p>
    </div>
  <% end %>
</div>
