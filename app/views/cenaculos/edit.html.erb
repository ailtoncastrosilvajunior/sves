<% content_for :title, "#{@cenaculo.nome} · Editar cenáculo · SVES" %>

<div class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-10 lg:px-8">
  <%= render "application/back_button", href: edicao_cenaculo_path(@edicao, @cenaculo), label: "Ficha do cenáculo" %>
  <p class="text-xs font-semibold uppercase tracking-wider text-stone-500">Edição <%= @edicao.rotulo %></p>
  <h1 class="mt-2 break-words font-display text-2xl tracking-tight text-stone-900 sm:text-3xl">Editar cenáculo</h1>
  <%= render "form" %>
</div>
