<% content_for :title, "Cenáculos · #{@edicao.rotulo} · SVES" %>

<div class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-10 lg:px-8">
  <% index_volta_href = pode_gerir_painel? ? edicao_path(@edicao) : root_path %>
  <% index_volta_label = pode_gerir_painel? ? "Edição" : "Início" %>
  <%= render "application/back_button", href: index_volta_href, label: index_volta_label %>
  <div class="flex flex-col gap-4">
    <div class="min-w-0">
      <p class="text-xs font-semibold uppercase tracking-wider text-stone-500">Edição <%= @edicao.rotulo %></p>
      <h1 class="mt-2 font-display text-2xl tracking-tight text-stone-900 sm:text-3xl">Cenáculos</h1>
      <p class="mt-2 text-sm text-stone-600">
        <% if pode_gerir_painel? %>
        Agrupe casais inscritos e defina os servos pastores de cada cenáculo. Nome e cor são únicos por edição.
        <% else %>
        Os cenáculos em que você participa como pastor nesta edição.
        <% end %>
      </p>
    </div>
    <% if pode_gerir_painel? %>
    <% btn_teal = "inline-flex min-h-[44px] w-full items-center justify-center whitespace-normal rounded-full border border-teal-200 bg-teal-50/70 px-4 py-2.5 text-center text-sm font-medium leading-snug text-teal-950 transition hover:bg-teal-100/70 sm:w-auto sm:min-h-[42px] sm:flex-shrink-0 sm:whitespace-nowrap sm:px-5 sm:py-2" %>
    <% btn_white = "inline-flex min-h-[44px] w-full items-center justify-center whitespace-normal rounded-full border border-stone-200 bg-white px-4 py-2.5 text-center text-sm font-medium leading-snug text-stone-800 shadow-sm ring-1 ring-stone-900/5 transition hover:border-stone-300 hover:bg-stone-50 sm:w-auto sm:min-h-[42px] sm:flex-shrink-0 sm:whitespace-nowrap sm:px-5 sm:py-2" %>
    <% btn_dark = "inline-flex min-h-[44px] w-full items-center justify-center whitespace-normal rounded-full bg-stone-900 px-4 py-2.5 text-center text-sm font-medium leading-snug text-white shadow-sm ring-1 ring-stone-900/5 transition hover:bg-stone-800 sm:w-auto sm:min-h-[42px] sm:flex-shrink-0 sm:whitespace-nowrap sm:px-5 sm:py-2" %>
    <div class="grid w-full min-w-0 grid-cols-2 gap-2 sm:flex sm:flex-row sm:flex-wrap sm:items-center sm:gap-3"
         role="toolbar"
         aria-label="Ações dos cenáculos">
      <% if administrador? %>
      <%= link_to t("cenaculos.distribuicao_sugestao.link_menu_cenarios"), edicao_distribuicao_cenaculos_sugestao_path(@edicao), class: btn_teal %>
      <% end %>
      <%= link_to t("reunioes_cenaculo.link_na_edicao"), edicao_reunioes_cenaculo_index_path(@edicao), class: btn_teal %>
      <%= link_to t("impressao_equipe_cenaculos.link_lista_cenaculos"), impressao_equipe_cenaculos_edicao_path(@edicao),
                  data: { turbo: false },
                  target: "_blank",
                  rel: "noopener noreferrer",
                  title: t("impressao_equipe_cenaculos.link_lista_cenaculos_title"),
                  class: btn_white %>
      <%= link_to "Novo cenáculo", new_edicao_cenaculo_path(@edicao), class: btn_dark %>
    </div>
    <% end %>
  </div>

  <% if @cenaculos.any? %>
    <ul class="mt-10 grid list-none gap-4 sm:grid-cols-1 xl:grid-cols-2">
      <% @cenaculos.each do |cenaculo| %>
        <% n_casais = cenaculo.cenaculo_casais.size %>
        <% n_pastores = cenaculo.cenaculo_servos.size %>
        <% linhas_coord = linhas_coordenacao_pastoral_cenaculo(cenaculo) %>
        <% tem_homens = cenaculo.local_homens.present? %>
        <% tem_mulheres = cenaculo.local_mulheres.present? %>
        <% cor_acento = cenaculo.cor.present? && cenaculo.cor.match?(Cenaculo::HEX_COR) ? cenaculo.cor : nil %>
        <li class="min-w-0">
          <%= link_to edicao_cenaculo_path(@edicao, cenaculo),
                      class: "group/card relative flex h-full min-h-[3.5rem] flex-col overflow-hidden rounded-2xl border border-stone-200/85 bg-white shadow-[0_1px_3px_rgb(0_0_0/0.06)] outline-none transition duration-200 hover:border-teal-300/65 hover:shadow-[0_4px_20px_-4px_rgb(0_0_0/0.08),0_0_0_1px_rgb(20_184_166/0.12)] focus-visible:ring-2 focus-visible:ring-teal-500/80 focus-visible:ring-offset-2" do %>
            <% bolinha_topo_cls = ["pointer-events-none absolute right-2.5 top-2.5 z-[2] sm:right-3.5 sm:top-3",
                                    "h-4 w-4 shrink-0 rounded-full shadow-[0_1px_4px_rgb(0_0_0/0.16)] ring-2 ring-white",
                                    ("bg-teal-500" if cor_acento.blank?)].compact.join(" ") %>
            <%= tag.span class: bolinha_topo_cls, style: (cor_acento.present? ? "background-color: #{cor_acento}" : nil), aria: { hidden: true } %>

            <div class="flex flex-1 flex-col gap-4 p-4 pr-11 pt-4 sm:flex-row sm:items-start sm:gap-5 sm:p-5 sm:pr-14 sm:pt-5">
              <div class="shrink-0 self-start">
                <%= cenaculo_index_card_miniatura(cenaculo, cor_acento: cor_acento) %>
              </div>

              <div class="min-w-0 flex-1 space-y-4">
                <div class="min-w-0">
                  <h2 class="font-display text-lg font-semibold leading-snug tracking-tight text-stone-900 sm:text-[1.125rem] sm:leading-tight">
                    <span class="transition-colors duration-200 group-hover/card:text-teal-950"><%= cenaculo.nome %></span>
                  </h2>
                </div>

                <div class="space-y-3">
                  <div class="rounded-xl bg-stone-50 px-3 py-2.5 ring-1 ring-stone-200/70">
                    <div class="flex flex-wrap items-center justify-between gap-x-2 gap-y-1">
                      <span class="text-[0.65rem] font-semibold uppercase tracking-wider text-stone-500"><%= t("cenaculos.index.secao_coordenacao_abrev") %></span>
                      <% if n_pastores.positive? %>
                        <span class="rounded-md bg-white/90 px-1.5 py-0.5 text-[0.65rem] font-semibold tabular-nums text-stone-600 ring-1 ring-stone-200/80"><%= t("cenaculos.index.stats_pastores", count: n_pastores) %></span>
                      <% end %>
                    </div>
                    <% if linhas_coord.any? %>
                      <p class="mt-2 line-clamp-3 text-sm leading-relaxed text-stone-800"><%= linhas_coord.join(" · ") %></p>
                    <% else %>
                      <p class="mt-2 text-sm leading-relaxed text-stone-500"><%= t("cenaculos.index.sem_coordenacao_curto") %></p>
                    <% end %>
                  </div>

                  <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
                    <div class="rounded-xl border border-stone-200/80 border-l-[3px] border-l-blue-600 bg-white px-3 py-2.5 shadow-sm">
                      <p class="flex items-center gap-1.5 text-[0.65rem] font-semibold uppercase tracking-wider text-blue-800">
                        <svg class="h-3.5 w-3.5 shrink-0 text-blue-700" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M8 14s5-3.13 5-7c0-2.76-2.24-5-5-5S3 4.24 3 7c0 3.87 5 7 5 7Z"/><circle cx="8" cy="7" r="1.75"/></svg>
                        <%= t("cenaculos.index.local_homens_abrev") %>
                      </p>
                      <p class="mt-1.5 line-clamp-2 text-sm leading-snug text-stone-800">
                        <% if tem_homens %>
                          <%= cenaculo.local_homens %>
                        <% else %>
                          <span class="text-stone-500"><%= t("cenaculos.index.sem_local_definido") %></span>
                        <% end %>
                      </p>
                    </div>
                    <div class="rounded-xl border border-stone-200/80 border-l-[3px] border-l-rose-600 bg-white px-3 py-2.5 shadow-sm">
                      <p class="flex items-center gap-1.5 text-[0.65rem] font-semibold uppercase tracking-wider text-rose-800">
                        <svg class="h-3.5 w-3.5 shrink-0 text-rose-700" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M8 14s5-3.13 5-7c0-2.76-2.24-5-5-5S3 4.24 3 7c0 3.87 5 7 5 7Z"/><circle cx="8" cy="7" r="1.75"/></svg>
                        <%= t("cenaculos.index.local_mulheres_abrev") %>
                      </p>
                      <p class="mt-1.5 line-clamp-2 text-sm leading-snug text-stone-800">
                        <% if tem_mulheres %>
                          <%= cenaculo.local_mulheres %>
                        <% else %>
                          <span class="text-stone-500"><%= t("cenaculos.index.sem_local_definido") %></span>
                        <% end %>
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="mt-auto flex min-h-[2.75rem] items-center justify-between gap-3 border-t border-stone-200/70 bg-stone-50/50 px-4 py-2.5 sm:px-5">
              <span class="inline-flex shrink-0 items-center rounded-full bg-white px-2.5 py-1 text-[0.65rem] font-semibold uppercase tracking-wide text-stone-600 tabular-nums shadow-sm ring-1 ring-stone-200/80">
                <%= t("cenaculos.index.stats_casais", count: n_casais) %>
              </span>
              <span class="inline-flex shrink-0 items-center gap-1 text-sm font-medium text-teal-800 transition-colors duration-200 group-hover/card:text-teal-950">
                <%= t("cenaculos.index.ver_cenaculo") %>
                <svg class="h-4 w-4 shrink-0 transition-transform duration-200 group-hover/card:translate-x-0.5" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8.293 3.293a1 1 0 0 1 1.414 0l4 4a1 1 0 0 1 0 1.414l-4 4a1 1 0 0 1-1.414-1.414L11.586 9H3a1 1 0 1 1 0-2h8.586L8.293 4.707a1 1 0 0 1 0-1.414z"/></svg>
              </span>
            </div>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="mt-10 rounded-2xl border border-dashed border-stone-300 bg-stone-50/50 px-5 py-8 text-center text-sm text-stone-600">
      <% if pode_gerir_painel? %>
      Ainda não há cenáculos nesta edição — crie o primeiro com o botão acima ou importando organização quando estiver disponível.
      <% else %>
      Ainda não há cenáculos associados a si nesta edição. Contacte a coordenação se algo estiver em falta.
      <% end %>
    </p>
  <% end %>
</div>
