<% content_for :title, "Cenáculos · #{@edicao.rotulo} · SVES" %>

<div class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-10 lg:px-8">
  <%= render "application/back_button", href: edicao_path(@edicao), label: "Ficha da edição" %>
  <div class="flex flex-col gap-4 sm:flex-row sm:flex-wrap sm:items-end sm:justify-between">
    <div class="min-w-0">
      <p class="text-xs font-semibold uppercase tracking-wider text-stone-500">Edição <%= @edicao.rotulo %></p>
      <h1 class="mt-2 font-display text-2xl tracking-tight text-stone-900 sm:text-3xl">Cenáculos</h1>
      <p class="mt-2 text-sm text-stone-600">
        <% if pode_gerir_painel? %>
        Agrupe casais inscritos e defina os servos «pastores» de cada cenáculo. Nome e cor são únicos por edição.
        <% else %>
        Os cenáculos em que você participa como pastor nesta edição.
        <% end %>
      </p>
    </div>
    <% if pode_gerir_painel? %>
    <%= link_to "Novo cenáculo", new_edicao_cenaculo_path(@edicao),
                class: "inline-flex min-h-[44px] w-full shrink-0 items-center justify-center rounded-full bg-stone-900 px-4 py-2.5 text-sm font-medium text-white shadow-sm ring-1 ring-stone-900/5 transition hover:bg-stone-800 sm:w-auto sm:min-h-0 sm:py-2" %>
    <% end %>
  </div>

  <% if @cenaculos.any? %>
    <ul class="mt-10 divide-y divide-stone-200/80 rounded-2xl border border-stone-200/80 bg-white/90 shadow-sm">
      <% @cenaculos.each do |cenaculo| %>
        <li>
          <%= link_to edicao_cenaculo_path(@edicao, cenaculo),
                      class: "flex min-h-[56px] flex-wrap items-center justify-between gap-4 px-5 py-4 transition hover:bg-stone-50/90 active:bg-stone-100/90 sm:min-h-0" do %>
            <div class="flex min-w-0 flex-wrap items-center gap-3">
              <% if cenaculo.imagem.attached? %>
                <%= image_tag cenaculo.imagem.variant(resize_to_limit: [112, 112]),
                              class: "h-14 w-14 shrink-0 rounded-xl object-cover ring-1 ring-stone-200/80",
                              alt: "" %>
              <% elsif cenaculo.cor.present? && cenaculo.cor.match?(Cenaculo::HEX_COR) %>
                <span class="h-14 w-14 shrink-0 rounded-xl ring-1 ring-stone-200/70" style="<%= "background-color: #{cenaculo.cor}" %>"></span>
              <% end %>
              <div class="min-w-0">
                <span class="block truncate font-medium text-stone-900"><%= cenaculo.nome %></span>
                <span class="mt-0.5 block text-xs text-stone-500">
                  <%= cenaculo.cenaculo_casais.size %> <%= cenaculo.cenaculo_casais.size == 1 ? "casal" : "casais" %>
                  <% n_p = cenaculo.cenaculo_servos.size %>
                  <% if n_p.positive? %>
                    · <%= n_p %> <%= n_p == 1 ? "pastor" : "pastores" %>
                  <% end %>
                </span>
              </div>
            </div>
            <span class="shrink-0 text-xs text-stone-500">Ver cenáculo →</span>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="mt-10 rounded-2xl border border-dashed border-stone-300 bg-stone-50/50 px-5 py-8 text-center text-sm text-stone-600">
      <% if pode_gerir_painel? %>
      Ainda não há cenáculos nesta edição — crie o primeiro com o botão acima ou importando organização quando estiver disponível.
      <% else %>
      Ainda não há cenáculos associados a si nesta edição. Contacte a coordenação se algo estiver em falta.
      <% end %>
    </p>
  <% end %>
</div>
