<%# Painel elaborado para escolha heterogênea de casais ainda disponíveis na edição. %>
<%# locals esperados implicitamente em show: @edicao, @cenaculo, @casais_para_adicionar %>
<div data-controller="distribuicao-casais"
     class="mt-8 rounded-2xl border border-teal-200/60 bg-gradient-to-b from-teal-50/40 to-white px-4 py-5 shadow-sm ring-1 ring-teal-100/70 sm:px-6">
  <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between lg:gap-8">
    <div class="min-w-0">
      <p class="text-sm font-semibold text-teal-950">Painel de distribuição · casais disponíveis</p>
      <p class="mt-2 max-w-prose text-sm leading-relaxed text-stone-700">
        Lista de casais da edição que <span class="font-medium text-teal-950">ainda não estão em nenhum cenáculo</span>:
      </p>
      <p class="mt-2 text-xs text-teal-900/85">
        Dica: na pesquisa pode combinar várias palavras (nomes completos ou de tratamento, etc.).
      </p>
    </div>
    <div class="shrink-0 text-sm">
      <%= link_to "Lista resumida de casais · edição",
                  edicao_casais_path(@edicao, v: "resumida"),
                  class: "font-medium text-stone-800 underline underline-offset-4 hover:text-stone-950" %>
    </div>
  </div>

  <% contagem_disp = @casais_para_adicionar.size %>
  <p class="mt-6 text-xs font-semibold uppercase tracking-wide text-stone-500">
    <% if contagem_disp == 1 %>
      1 casal disponível na lista seguinte para integrar cenáculos
    <% else %>
      <%= "#{contagem_disp} casais disponíveis na lista seguinte para integrar cenáculos" %>
    <% end %>
  </p>

  <div class="mt-5 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
    <div class="min-w-0 flex-1">
      <%= label_tag dom_id(@cenaculo, :filtro_cas_distribuicao),
                    "Filtrar candidatos",
                    class: "sr-only" %>
      <%= text_field_tag :filtro_distribuicao,
                         "",
                         id: dom_id(@cenaculo, :filtro_cas_distribuicao),
                         autocomplete: "off",
                         placeholder: "Ex.: zona sul · primeira vez · música · com filhos abc…",
                         data: {
                           distribuicao_casais_target: "campoBusca",
                           action: "input->distribuicao-casais#atualizarFiltragem",
                         },
                         class: "min-h-[48px] w-full rounded-xl border border-stone-300 bg-white px-4 py-2.5 text-sm text-stone-900 shadow-inner outline-none ring-stone-400/30 placeholder:text-stone-400 focus:border-teal-600/60 focus:ring-2 focus:ring-teal-500/20 sm:min-h-10" %>
    </div>
    <%= button_tag "Limpar filtro",
                   type: "button",
                   data: { action: "click->distribuicao-casais#limparCampoBusca" },
                   class: "inline-flex min-h-[48px] cursor-pointer items-center justify-center rounded-full border border-stone-300 bg-white px-5 py-2 text-sm font-medium text-stone-800 shadow-sm transition hover:bg-stone-50 sm:min-h-10" %>
  </div>

  <p data-distribuicao-casais-target="semResultados"
     class="mt-4 hidden rounded-xl border border-amber-200/90 bg-amber-50 px-4 py-3 text-sm leading-relaxed text-amber-950"
     role="status">
    Nenhum casal coincide com estas palavras — alargue ou limpe o filtro.
  </p>

  <p role="status" aria-live="polite"
     data-distribuicao-casais-target="resultadoFiltragem"
     class="mt-3 hidden rounded-lg bg-teal-100/70 px-3 py-2 text-sm font-medium text-teal-950"></p>

  <div class="mt-5 max-h-[min(70vh,44rem)] min-w-0 w-full overflow-y-auto overflow-x-hidden rounded-2xl border border-stone-200/70 bg-white/90 pr-2 shadow-inner">
    <ul class="space-y-5 p-4 sm:p-5">
      <% @casais_para_adicionar.each do |casal| %>
        <%= tag.li class: "min-w-0 rounded-2xl border border-stone-200 bg-white px-5 py-4 shadow-sm transition hover:border-teal-300/55 hover:bg-teal-50/25",
                     data: {
                       distribuicao_casais_target: "cartao",
                       busca: texto_busca_distribuicao_casal(casal),
                     } do %>
          <div class="flex w-full min-w-0 flex-col gap-5 lg:flex-row lg:items-start lg:justify-between lg:gap-8">
            <%= render "casais/detalhe_casal_completo", casal: casal %>

            <div class="flex w-full min-w-0 shrink-0 flex-col gap-3 border-t border-dashed border-stone-200 pt-5 lg:w-56 lg:border-l lg:border-t-0 lg:pl-6 lg:pt-0">
              <%= button_to "Adicionar a este cenáculo",
                            [@edicao, @cenaculo, CenaculoCasal.new],
                            method: :post,
                            params: { cenaculo_casal: { casal_id: casal.id } },
                            class: "inline-flex min-h-[48px] w-full cursor-pointer items-center justify-center rounded-full bg-teal-800 px-5 py-2.5 text-sm font-semibold text-white shadow-sm ring-1 ring-teal-900/15 transition hover:bg-teal-900 sm:min-h-11 lg:w-56 lg:self-start" %>
              <p class="break-words text-center text-[11px] leading-snug text-stone-400 lg:text-left lg:text-xs lg:leading-relaxed lg:text-stone-500">
                Nesta edição cada casal entra apenas num cenáculo. Para mudar de grupo, retire-o primeiro do outro cenáculo; então volta a aparecer aqui como disponível.
              </p>
            </div>
          </div>
        <% end %>
      <% end %>
    </ul>
  </div>
</div>
