<% content_for :title, t("material_apoio.meta.titulo_gestao") %>

<div class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-10 lg:px-8">
  <%= render "application/back_button", href: materiais_apoio_path, label: "Lista pública" %>
  <div class="flex flex-col gap-4 sm:flex-row sm:flex-wrap sm:items-end sm:justify-between">
    <div class="min-w-0">
      <h1 class="font-display text-2xl tracking-tight text-stone-900 sm:text-3xl"><%= t("material_apoio.todos.heading") %></h1>
      <p class="mt-2 text-sm text-stone-600"><%= t("material_apoio.todos.subheading") %></p>
      <div class="mt-3 flex flex-wrap gap-x-4 gap-y-2 text-xs text-stone-500">
        <%= link_to t("material_apoio.links.ver_lista_publica"),
                    materiais_apoio_path,
                    class: "font-medium text-teal-800 underline decoration-teal-300 underline-offset-4 hover:text-teal-950" %>
      </div>
    </div>
    <%= link_to t("material_apoio.links.novo"),
                new_material_apoio_path,
                class: "inline-flex min-h-[44px] w-full shrink-0 items-center justify-center rounded-full bg-stone-900 px-4 py-2.5 text-sm font-medium text-white shadow-sm ring-1 ring-stone-900/5 transition hover:bg-stone-800 sm:w-auto sm:min-h-0 sm:py-2" %>
  </div>

  <% if @materiais.any? %>
    <ul class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-2 sm:gap-5 lg:grid-cols-2" role="list">
      <% @materiais.each do |m| %>
        <li class="min-w-0">
          <article class="flex h-full flex-col overflow-hidden rounded-2xl border border-stone-200/90 bg-gradient-to-b from-white via-white to-stone-50/90 p-5 shadow-sm ring-1 ring-stone-900/[0.035] transition duration-200 hover:border-teal-200/70 hover:shadow-md hover:shadow-teal-900/10 sm:p-6">
            <div class="flex gap-4">
              <%= render "materiais_apoio/icone_documento" %>
              <div class="min-w-0 flex-1 space-y-2">
                <div class="flex flex-wrap items-center gap-2 gap-y-1.5">
                  <h2 class="min-w-0 font-display text-lg font-medium leading-snug tracking-tight text-stone-900"><%= m.titulo %></h2>
                  <% if m.ativo? %>
                    <span class="shrink-0 rounded-full bg-emerald-50 px-2 py-0.5 text-[0.65rem] font-semibold uppercase tracking-wide text-emerald-950 ring-1 ring-emerald-200/80"><%= t("material_apoio.estado.publico") %></span>
                  <% else %>
                    <span class="shrink-0 rounded-full bg-stone-200/70 px-2 py-0.5 text-[0.65rem] font-semibold uppercase tracking-wide text-stone-700 ring-1 ring-stone-300/60"><%= t("material_apoio.estado.fora_ar") %></span>
                  <% end %>
                  <span class="shrink-0 rounded-md bg-stone-100/90 px-2 py-0.5 text-[0.65rem] font-medium text-stone-600"><%= t("material_apoio.todos.rotulo_ordem", n: m.ordem) %></span>
                </div>
                <% if m.descricao.present? %>
                  <p class="line-clamp-4 text-sm leading-relaxed text-stone-600 sm:line-clamp-none sm:whitespace-pre-wrap"><%= m.descricao %></p>
                <% end %>
                <% unless m.arquivo.attached? %>
                  <p class="rounded-lg border border-dashed border-amber-300/90 bg-amber-50/80 px-3 py-2 text-xs text-amber-950"><%= t("material_apoio.todos.sem_ficheiro") %></p>
                <% end %>
              </div>
            </div>
            <% if m.arquivo.attached? || administrador? %>
              <div class="mt-5 border-t border-stone-200/60 pt-4">
                <% if m.arquivo.attached? && administrador? %>
                  <div class="grid grid-cols-3 gap-1.5 sm:flex sm:flex-row sm:flex-wrap sm:justify-end sm:gap-2">
                    <%= link_to t("material_apoio.links.baixar_teste"),
                                baixar_material_apoio_path(m),
                                class: "inline-flex min-h-10 items-center justify-center rounded-full bg-teal-800 px-1.5 py-2 text-center text-[0.65rem] font-semibold leading-tight text-white shadow-sm ring-1 ring-teal-900/20 transition hover:bg-teal-900 active:bg-teal-950 sm:order-3 sm:min-h-9 sm:px-4 sm:text-sm" %>
                    <%= link_to t("material_apoio.links.editar"),
                                edit_material_apoio_path(m),
                                class: "inline-flex min-h-10 items-center justify-center rounded-full border border-stone-300 bg-white px-1.5 py-2 text-center text-[0.65rem] font-medium leading-tight text-stone-800 shadow-sm transition hover:bg-stone-50 sm:order-2 sm:min-h-9 sm:px-4 sm:text-sm" %>
                    <%= button_to t("material_apoio.links.excluir"),
                                  material_apoio_path(m),
                                  method: :delete,
                                  form: { class: "m-0 min-w-0 sm:order-1 sm:inline-block sm:w-auto" },
                                  class: "flex min-h-10 w-full cursor-pointer items-center justify-center rounded-full border border-rose-200/90 bg-rose-50/90 px-1.5 py-2 text-center text-[0.65rem] font-medium leading-tight text-rose-900 transition hover:border-rose-300 hover:bg-rose-100/90 sm:min-h-9 sm:w-auto sm:px-4 sm:text-sm",
                                  data: { turbo_confirm: t("material_apoio.confirmar_remover", titulo: m.titulo) } %>
                  </div>
                <% elsif m.arquivo.attached? %>
                  <%= link_to t("material_apoio.links.baixar_teste"),
                              baixar_material_apoio_path(m),
                              class: "inline-flex min-h-11 w-full items-center justify-center rounded-full bg-teal-800 px-4 py-2.5 text-center text-sm font-semibold text-white shadow-sm ring-1 ring-teal-900/20 transition hover:bg-teal-900 sm:w-auto" %>
                <% elsif administrador? %>
                  <div class="grid grid-cols-2 gap-1.5 sm:flex sm:justify-end sm:gap-2">
                    <%= link_to t("material_apoio.links.editar"),
                                edit_material_apoio_path(m),
                                class: "inline-flex min-h-10 items-center justify-center rounded-full border border-stone-300 bg-white px-2 py-2 text-center text-xs font-medium text-stone-800 shadow-sm transition hover:bg-stone-50 sm:min-h-9 sm:px-4 sm:text-sm" %>
                    <%= button_to t("material_apoio.links.excluir"),
                                  material_apoio_path(m),
                                  method: :delete,
                                  form: { class: "m-0 min-w-0 sm:inline-block sm:w-auto" },
                                  class: "flex min-h-10 w-full cursor-pointer items-center justify-center rounded-full border border-rose-200/90 bg-rose-50/90 px-2 py-2 text-center text-xs font-medium text-rose-900 transition hover:border-rose-300 hover:bg-rose-100/90 sm:min-h-9 sm:w-auto sm:px-4 sm:text-sm",
                                  data: { turbo_confirm: t("material_apoio.confirmar_remover", titulo: m.titulo) } %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </article>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="mt-10 rounded-2xl border border-dashed border-stone-300 bg-stone-50/50 px-5 py-8 text-center text-sm text-stone-600"><%= t("material_apoio.todos.vazio") %></p>
  <% end %>
</div>
