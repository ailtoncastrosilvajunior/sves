<% content_for :title, t("material_apoio.meta.titulo_index") %>

<div class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-10 lg:px-8">
  <%= render "application/back_button", href: root_path, label: "Início" %>
  <div class="flex flex-col gap-4 sm:flex-row sm:flex-wrap sm:items-end sm:justify-between">
    <div class="min-w-0">
      <h1 class="font-display text-2xl tracking-tight text-stone-900 sm:text-3xl"><%= t("material_apoio.index.heading") %></h1>
      <p class="mt-2 text-sm text-stone-600"><%= t("material_apoio.index.subheading") %></p>
      <% if pode_gerir_painel? %>
      <div class="mt-3 flex flex-wrap gap-x-4 gap-y-2 text-xs text-stone-500">
        <%= link_to t("material_apoio.links.gestao_todos"),
                    todos_materiais_apoio_path,
                    class: "font-medium text-stone-700 underline decoration-stone-300 underline-offset-4 hover:text-stone-900" %>
      </div>
      <% end %>
    </div>
    <% if pode_gerir_painel? %>
    <%= link_to t("material_apoio.links.novo"),
                new_material_apoio_path,
                class: "inline-flex min-h-[44px] w-full shrink-0 items-center justify-center rounded-full bg-stone-900 px-4 py-2.5 text-sm font-medium text-white shadow-sm ring-1 ring-stone-900/5 transition hover:bg-stone-800 sm:w-auto sm:min-h-0 sm:py-2" %>
    <% end %>
  </div>

  <% if @materiais.any? %>
    <ul class="mt-10 divide-y divide-stone-200/80 rounded-2xl border border-stone-200/80 bg-white/80 shadow-sm">
      <% @materiais.each do |m| %>
        <li class="flex flex-col gap-3 px-5 py-4 sm:flex-row sm:items-start sm:justify-between sm:gap-4">
          <div class="min-w-0 flex-1">
            <span class="block font-medium text-stone-900"><%= m.titulo %></span>
            <% if m.descricao.present? %>
              <p class="mt-2 text-sm leading-relaxed text-stone-600 whitespace-pre-wrap"><%= m.descricao %></p>
            <% end %>
            <% blob = m.arquivo.blob %>
            <p class="mt-3 flex flex-wrap items-center gap-x-2 gap-y-1 text-xs text-stone-500">
              <kbd class="rounded-md bg-stone-100 px-1.5 py-0.5 font-mono text-stone-800 ring-1 ring-stone-200/80"><%= blob.filename.to_s %></kbd>
              <span>· <%= number_to_human_size(blob.byte_size, precision: 1) %></span>
            </p>
          </div>
          <div class="shrink-0 sm:pt-0.5">
            <%= link_to t("material_apoio.links.baixar"),
                        baixar_material_apoio_path(m),
                        class: "inline-flex min-h-[44px] w-full items-center justify-center rounded-full border border-stone-900/15 bg-white px-4 py-2.5 text-center text-sm font-semibold text-stone-900 shadow-sm transition hover:bg-stone-50 sm:min-h-0 sm:w-auto sm:py-2" %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="mt-10 rounded-2xl border border-dashed border-stone-300 bg-stone-50/50 px-5 py-8 text-center text-sm text-stone-600">
      <%= t("material_apoio.index.vazio_html") %>
    </p>
  <% end %>
</div>
