<%# locals opcionais — usa @material %>
<%= form_with model: @material, class: "space-y-6" do |f| %>
  <% if @material.errors.any? %>
    <div role="alert" class="rounded-2xl border border-rose-200/90 bg-rose-50 px-5 py-4 text-sm text-rose-900">
      <p class="font-medium">Não foi possível gravar este material:</p>
      <ul class="mt-3 list-disc space-y-1 pl-5 marker:text-rose-500">
        <% @material.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="rounded-2xl border border-stone-200/80 bg-white p-6 shadow-sm sm:p-8">
    <div class="space-y-6">
      <div>
        <%= f.label :titulo, class: "block text-sm font-medium text-stone-800" %>
        <%= f.text_field :titulo, required: true, autocomplete: "off",
                         class: "mt-2 block w-full rounded-xl border border-stone-300 bg-white px-3 py-3 text-[1rem] text-stone-900 shadow-sm outline-none transition placeholder:text-stone-400 focus:border-stone-500 focus:ring-2 focus:ring-stone-400/30 sm:text-sm" %>
      </div>

      <div>
        <%= f.label :descricao, "#{MaterialApoio.human_attribute_name(:descricao)} (opcional)", class: "block text-sm font-medium text-stone-800" %>
        <%= f.text_area :descricao, rows: 4,
                        class: "mt-2 block w-full rounded-xl border border-stone-300 bg-white px-3 py-3 text-sm leading-relaxed text-stone-900 shadow-sm outline-none transition placeholder:text-stone-400 focus:border-stone-500 focus:ring-2 focus:ring-stone-400/30" %>
        <p class="mt-1.5 text-xs text-stone-500">Opcional · texto breve antes do download.</p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2">
        <div>
          <%= f.label :ordem, class: "block text-sm font-medium text-stone-800" %>
          <%= f.number_field :ordem,
                             step: 1,
                             class: "mt-2 block w-full rounded-xl border border-stone-300 bg-white px-3 py-3 text-[1rem] text-stone-900 shadow-sm outline-none transition focus:border-stone-500 focus:ring-2 focus:ring-stone-400/30 sm:text-sm" %>
          <p class="mt-1.5 text-xs text-stone-500">Menor número aparece primeiro na lista.</p>
        </div>

        <div class="flex items-end pb-2">
          <div class="flex min-h-[44px] flex-col justify-center rounded-xl border border-stone-200 bg-stone-50/70 px-4 py-3 sm:min-h-0 sm:w-full">
            <%= f.label :ativo, class: "flex cursor-pointer items-start gap-3 text-sm leading-snug text-stone-800" do %>
              <%= f.check_box :ativo,
                              class: "mt-1 h-5 w-5 shrink-0 rounded border border-stone-400 text-teal-600 focus:ring-stone-500" %>
              <span>
                <span class="block font-medium">Mostrar aos servos (ativo)</span>
                <span class="mt-1 block text-xs font-normal text-stone-600">Desmarque para tirar do ar sem excluir o registro nem o arquivo.</span>
              </span>
            <% end %>
          </div>
        </div>
      </div>

      <div class="rounded-xl border border-dashed border-stone-300 bg-stone-50/40 px-4 py-4 sm:p-5">
        <%= f.label :arquivo do %>
          <% if @material.persisted? && @material.arquivo.attached? %>
            <% blob = @material.arquivo.blob %>
            <span class="block text-sm font-medium text-stone-900">Substituir arquivo (opcional)</span>
            <p class="mt-1 flex flex-wrap items-center gap-x-2 gap-y-1 text-xs text-stone-600">
              <span>Arquivo atual:</span>
              <kbd class="rounded-md bg-white px-1.5 py-0.5 font-mono text-xs text-stone-800 ring-1 ring-stone-200"><%= blob.filename %></kbd>
              <span>· <%= number_to_human_size(blob.byte_size, precision: 1) %></span>
              <% if blob.content_type.present? %>
                <span class="text-stone-500">· <%= blob.content_type %></span>
              <% end %>
            </p>
          <% else %>
            <span class="block text-sm font-medium text-stone-900"><%= MaterialApoio.human_attribute_name(:arquivo) %></span>
            <p class="mt-1 text-xs text-stone-600"><%= I18n.t("material_apoio.form_tipos_anexo") %></p>
          <% end %>
        <% end %>
        <%= f.file_field :arquivo,
                         accept: "application/pdf,.doc,.docx,.odt,application/msword",
                         class: "mt-4 block w-full text-sm text-stone-700 file:mr-3 file:inline-flex file:rounded-full file:border-0 file:bg-stone-900 file:px-4 file:py-2 file:text-xs file:font-semibold file:text-white file:transition file:hover:bg-stone-800" %>
      </div>

      <% if @material.persisted? && @material.arquivo.attached? %>
        <div class="rounded-xl border border-amber-100 bg-amber-50/70 px-4 py-3 space-y-2">
          <%= hidden_field_tag "material_apoio[remove_arquivo]", "0" %>
          <label class="flex cursor-pointer items-start gap-3 text-sm text-amber-950">
            <%= check_box_tag "material_apoio[remove_arquivo]", "1", false,
                              id: "material_apoio_remove_arquivo",
                              class: "mt-1 h-5 w-5 shrink-0 rounded border border-amber-300 text-amber-700 focus:ring-amber-500" %>
            <span>Eliminar o arquivo anexo ao gravar. <%= t("material_apoio.mensagem_checkbox_remove") %></span>
          </label>
        </div>
      <% end %>
    </div>

    <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <%= link_to (@material.persisted? ? todos_materiais_apoio_path : materiais_apoio_path),
                  class: "order-3 inline-flex min-h-[44px] w-full items-center justify-center rounded-full border border-stone-300 bg-white px-4 py-2.5 text-center text-sm font-medium text-stone-800 hover:bg-stone-50 sm:order-none sm:w-auto sm:min-h-0 sm:py-2" do %>
        Cancelar
      <% end %>
      <%= f.submit (@material.persisted? ? "Atualizar material" : "Registrar material"),
                   class: "order-2 inline-flex min-h-[44px] w-full items-center justify-center rounded-full bg-stone-900 px-5 py-2.5 text-sm font-semibold text-white shadow-sm ring-1 ring-stone-900/5 hover:bg-stone-800 disabled:opacity-75 sm:order-none sm:w-auto sm:py-2" %>
    </div>
  </div>
<% end %>
